---
/**
 * BlogLayout - Layout for individual blog post pages
 * Extends BaseLayout with blog-specific metadata and structure
 * 
 * Props:
 * - title: Blog post title (required)
 * - description: Blog post summary for SEO (required)
 * - date: Publication date (required)
 * - tags: Optional array of tags
 * - slug: Blog post slug for canonical URL (required)
 */

import Navigation from '../components/ui/Navigation.astro';
import Footer from '../components/ui/Footer.astro';
import ViewCounter from '../components/blogs/ViewCounter.astro';

// Import CSS files so Astro can process them
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/typography.css';
import '../styles/motion.css';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

// Format date for display
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(date);

// Get canonical URL
const canonicalURL = new URL(`/blogs/${slug}`, Astro.site || Astro.url.origin);

// Open Graph image (using a default for now)
const ogImage = new URL('/favicon.svg', Astro.site || Astro.url.origin);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage.href} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage.href} />
    
    <!-- Article Meta -->
    <meta property="article:published_time" content={date.toISOString()} />
    {tags && tags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- FontAwesome Icons -->
    <script src="https://kit.fontawesome.com/3f7347f781.js" crossorigin="anonymous"></script>
  </head>
  <body>
    <!-- Skip to content link for accessibility -->
    <a href="#main-content" class="skip-to-content">
      Skip to main content
    </a>
    
    <div class="page-layout depth-mid">
      <header class="page-nav depth-near" role="banner">
        <Navigation />
      </header>
      
      <main id="main-content" class="blog-detail" role="main">
        <article class="blog-article">
          <header class="blog-header">
            <h1 class="blog-title">{title}</h1>
            
            <div class="blog-meta">
              <time datetime={date.toISOString()} class="blog-date">
                {formattedDate}
              </time>
              
              <!-- View Counter -->
              <ViewCounter slug={slug} />
              
              {tags && tags.length > 0 && (
                <div class="blog-tags" role="list" aria-label="Article tags">
                  {tags.map(tag => (
                    <span class="blog-tag" role="listitem">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            
            <p class="blog-summary">{description}</p>
          </header>
          
          <div class="blog-content">
            <slot />
          </div>
        </article>
      </main>

      <Footer currentPath={Astro.url.pathname} />
    </div>
    
    <!-- Load view counter client script -->
    <script>
      import { initViewCounters } from '../components/blogs/ViewCounterClient';
      initViewCounters();
    </script>
  </body>
</html>

<style>
  .page-layout {
    min-height: 100vh;
    background: 
      radial-gradient(
        ellipse at center top,
        var(--color-bg-light) 0%,
        var(--color-bg-mid) 30%,
        var(--color-bg-dark) 70%,
        var(--color-bg-deep) 100%
      ),
      /* Atmospheric texture overlay */
      radial-gradient(circle at 30% 20%, rgba(246, 224, 94, 0.02) 0%, transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(139, 149, 109, 0.015) 0%, transparent 50%);
  }

  .page-nav {
    position: sticky;
    top: 0;
    z-index: var(--layer-navigation);
    background: linear-gradient(
      180deg,
      var(--color-surface-elevated) 0%,
      rgba(42, 47, 54, 0.95) 100%
    );
    backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--color-border-accent);
    padding: var(--space-4) var(--space-6);
    box-shadow: var(--panel-shadow-base);
  }

  .page-nav :global(.navigation) {
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-detail {
    max-width: 65ch;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6);
  }
  
  .blog-article {
    animation: fadeIn var(--duration-medium) var(--ease-out);
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(var(--space-4));
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .blog-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border-medium);
  }
  
  .blog-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
  }
  
  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    margin-bottom: var(--space-6);
  }
  
  .blog-date {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-weight: var(--weight-medium);
  }
  
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .blog-tag {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    background: var(--color-surface-base);
    padding: var(--space-1) var(--space-3);
    border-radius: 4px;
    border: 1px solid var(--color-border-medium);
  }
  
  .blog-summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    font-style: italic;
  }
  
  .blog-content {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-primary);
  }
  
  /* Markdown content styling */
  .blog-content :global(h1),
  .blog-content :global(h2),
  .blog-content :global(h3),
  .blog-content :global(h4),
  .blog-content :global(h5),
  .blog-content :global(h6) {
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }
  
  .blog-content :global(h1) {
    font-size: var(--text-3xl);
  }
  
  .blog-content :global(h2) {
    font-size: var(--text-2xl);
  }
  
  .blog-content :global(h3) {
    font-size: var(--text-xl);
  }
  
  .blog-content :global(p) {
    margin-bottom: var(--space-6);
  }
  
  .blog-content :global(a) {
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-color: var(--color-border-medium);
    text-underline-offset: 2px;
    transition: color var(--duration-fast) var(--ease-out);
  }
  
  .blog-content :global(a:hover) {
    color: var(--color-link-hover);
    text-decoration-color: var(--color-link-hover);
  }
  
  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-8);
  }
  
  .blog-content :global(li) {
    margin-bottom: var(--space-3);
  }
  
  .blog-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface-base);
    padding: var(--space-1) var(--space-2);
    border-radius: 3px;
    border: 1px solid var(--color-border-medium);
  }
  
  .blog-content :global(pre) {
    background: var(--color-surface-base);
    padding: var(--space-4);
    border-radius: 6px;
    border: 1px solid var(--color-border-medium);
    overflow-x: auto;
    margin-bottom: var(--space-6);
  }
  
  .blog-content :global(pre code) {
    background: none;
    padding: 0;
    border: none;
  }
  
  .blog-content :global(blockquote) {
    border-left: 3px solid var(--color-accent-primary);
    padding-left: var(--space-6);
    margin-left: 0;
    margin-bottom: var(--space-6);
    color: var(--color-text-secondary);
    font-style: italic;
  }
  
  .blog-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: var(--space-8) 0;
  }
  
  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border-medium);
    margin: var(--space-12) 0;
  }
  
  /* Responsive adjustments */
  @media (max-width: var(--breakpoint-lg)) {
    .blog-detail {
      padding: var(--space-8) var(--space-4);
    }
    
    .blog-title {
      font-size: var(--text-3xl);
    }
    
    .blog-summary {
      font-size: var(--text-base);
    }
  }
  
  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .blog-article {
      animation: none;
    }
  }
</style>
