---
/**
 * BaseLayout - Base layout component for all pages
 * Provides consistent head metadata, style imports, and page structure
 * 
 * Props:
 * - title: Page title (required)
 * - description: Meta description for SEO (optional)
 * - noScroll: Disable scrolling (for home page) (optional)
 * - ogImage: Open Graph image URL (optional, defaults to favicon)
 * - ogType: Open Graph type (optional, defaults to 'website')
 * - lang: Language code (optional, defaults to 'en')
 */

// Import CSS files so Astro can process them
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/typography.css';
import '../styles/motion.css';
import '../styles/scrollbar.css';

import { getLangFromUrl } from '../i18n/utils';
import CustomCursor from '../components/ui/CustomCursor.astro';

interface Props {
  title: string;
  description?: string;
  noScroll?: boolean;
  ogImage?: string;
  ogType?: 'website' | 'article';
  lang?: string;
}

const { 
  title, 
  description, 
  noScroll = false,
  ogImage,
  ogType = 'website',
  lang
} = Astro.props;

// Get language from URL or use provided lang
const currentLang = lang || getLangFromUrl(Astro.url);

// Get canonical URL for this page
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);

// Default Open Graph image (use favicon if no image provided)
const defaultOgImage = new URL('/favicon.svg', Astro.site || Astro.url.origin);
const ogImageURL = ogImage ? new URL(ogImage, Astro.site || Astro.url.origin) : defaultOgImage;
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    {description && <meta name="description" content={description} />}
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:site_name" content="HD-2D Portfolio" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL.href} />
    <meta property="twitter:title" content={title} />
    {description && <meta property="twitter:description" content={description} />}
    <meta property="twitter:image" content={ogImageURL.href} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Theme color for browser chrome (matches dark theme background) -->
    <meta name="theme-color" content="#1a1c24" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    
    <!-- Theme initialization (inline to prevent FOUC) -->
    <script is:inline>
      // Initialize theme immediately to prevent flash
      (function() {
        const THEME_KEY = 'portfolio-theme';
        
        function getStoredTheme() {
          try {
            return localStorage.getItem(THEME_KEY);
          } catch {
            return null;
          }
        }
        
        function getSystemTheme() {
          return window.matchMedia('(prefers-color-scheme: light)').matches 
            ? 'light' 
            : 'dark';
        }
        
        const theme = getStoredTheme() || getSystemTheme();
        document.documentElement.setAttribute('data-theme', theme);
      })();
      
      // Initialize language immediately to prevent flash
      (function() {
        const LANG_KEY = 'portfolio-language';
        
        function getStoredLanguage() {
          try {
            return localStorage.getItem(LANG_KEY);
          } catch {
            return null;
          }
        }
        
        function getBrowserLanguage() {
          const browserLang = navigator.language.toLowerCase();
          return browserLang.startsWith('id') ? 'id' : 'en';
        }
        
        const lang = getStoredLanguage() || getBrowserLanguage();
        document.documentElement.setAttribute('lang', lang);
      })();
    </script>
    
    <!-- FontAwesome Icons - Latest CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>
  <body class:list={[{ 'no-scroll': noScroll }]}>
    <!-- Skip to content link for accessibility -->
    <a href="#main-content" class="skip-to-content">
      Skip to main content
    </a>
    
    <!-- Custom Cursor (desktop only) -->
    <CustomCursor />
    
    <slot />
  </body>
</html>
