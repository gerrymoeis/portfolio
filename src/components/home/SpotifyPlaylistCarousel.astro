---
/**
 * SpotifyPlaylistCarousel - Single iframe carousel with dynamic src switching
 * Simple, clean implementation using one iframe that changes src on navigation
 */

import { spotifyConfig, validatePlaylists, type CarouselProps, type SpotifyPlaylist } from '../../config/spotify';
import SpotifyEmbed from './SpotifyEmbed.astro';
import NavigationControls from './NavigationControls.astro';
import PaginationIndicator from './PaginationIndicator.astro';

export interface Props extends Partial<CarouselProps> {
  /** Override default playlists from config */
  playlists?: SpotifyPlaylist[];
  /** Additional CSS class names */
  className?: string;
}

const { 
  playlists = spotifyConfig.playlists,
  autoplay = spotifyConfig.carouselSettings?.autoplay ?? false,
  showControls = spotifyConfig.carouselSettings?.showControls ?? true,
  className = ''
} = Astro.props;

// Validate playlists and handle errors
const { validPlaylists, errors } = validatePlaylists(playlists);

// Log validation errors in development
if (errors.length > 0 && import.meta.env.DEV) {
  console.warn('Spotify Playlist Carousel validation errors:', errors);
}

// Determine if we should show carousel controls
const isMultiplePlaylist = validPlaylists.length > 1;
const shouldShowControls = isMultiplePlaylist && showControls;

// Generate unique IDs for accessibility
const carouselId = `spotify-carousel-${Math.random().toString(36).substring(2, 9)}`;
const liveRegionId = `${carouselId}-live-region`;

// If no valid playlists, don't render anything
if (validPlaylists.length === 0 && import.meta.env.DEV) {
  console.error('No valid Spotify playlists found. Carousel will not render.');
}
---

{validPlaylists.length > 0 && (
  <div 
    class={`spotify-playlist-carousel ${className}`}
    role="region"
    aria-label="Spotify playlist carousel"
    aria-describedby={liveRegionId}
    data-carousel-id={carouselId}
    data-total-playlists={validPlaylists.length}
    data-autoplay={autoplay}
    data-show-controls={shouldShowControls}
    data-playlists={JSON.stringify(validPlaylists)}
  >
    <!-- Accessibility: Live region for screen reader announcements -->
    <div 
      id={liveRegionId}
      class="carousel-live-region"
      aria-live="polite"
      aria-atomic="true"
    >
      Showing playlist 1 of {validPlaylists.length}: {validPlaylists[0]?.title}
    </div>

    <!-- Single Spotify embed that changes src dynamically -->
    <div class="carousel-embed-container">
      <SpotifyEmbed 
        embedUrl={validPlaylists[0]?.embedUrl}
        description={validPlaylists[0]?.title}
        isCarousel={true}
      />
    </div>

    <!-- Navigation controls (only shown for multiple playlists) -->
    {shouldShowControls && (
      <NavigationControls 
        currentIndex={0}
        totalPlaylists={validPlaylists.length}
        showControls={shouldShowControls}
        labels={{
          previous: "Previous playlist",
          next: "Next playlist"
        }}
      />
    )}

    <!-- Pagination indicators (only shown for multiple playlists) -->
    {shouldShowControls && (
      <PaginationIndicator 
        playlists={validPlaylists}
        currentIndex={0}
        clickable={true}
        className="carousel-pagination-component"
        ariaLabel="Playlist navigation indicators"
      />
    )}
  </div>
)}

<style>
  .spotify-playlist-carousel {
    position: relative;
    width: 100%;
    max-width: 100%;
    isolation: isolate;
  }

  /* Accessibility: Hide live region visually but keep it available to screen readers */
  .carousel-live-region {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Single embed container */
  .carousel-embed-container {
    width: 100%;
    height: 352px; /* Fixed height to prevent layout issues */
  }

  /* Pagination indicators styling - compact version */
  .carousel-pagination-component {
    margin-top: 2px; /* Minimal margin - reduced from var(--space-1) */
  }

  /* Responsive adjustments */
  @media (max-width: var(--breakpoint-md)) {
    .carousel-pagination {
      margin-top: var(--space-3);
    }
  }

  /* Dark mode adjustments */
  @media (prefers-color-scheme: dark) {
    .pagination-dot__indicator {
      background: var(--color-text-tertiary);
    }
    
    .pagination-dot--active .pagination-dot__indicator {
      background: var(--color-accent-primary);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .pagination-dot,
    .pagination-dot__indicator {
      transition: none;
    }
    
    .pagination-dot:hover {
      transform: none;
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .pagination-dot__indicator {
      border: 1px solid currentColor;
    }
  }
</style>

<script>
  // Single iframe carousel using Spotify iframe API
  class SpotifyPlaylistCarousel {
    private container: HTMLElement;
    private liveRegion: HTMLElement;
    private currentIndex: number = 0;
    private totalPlaylists: number;
    private playlists: any[];
    private spotifyController: any = null;
    
    constructor(container: HTMLElement) {
      this.container = container;
      this.liveRegion = container.querySelector('.carousel-live-region') as HTMLElement;
      this.totalPlaylists = parseInt(container.dataset.totalPlaylists || '0', 10);
      this.playlists = JSON.parse(container.dataset.playlists || '[]');
      
      this.init();
    }
    
    private init() {
      if (this.totalPlaylists <= 1) return;
      
      this.setupEventListeners();
      this.updateAccessibility();
      
      // Wait for Spotify controller to be ready
      this.waitForSpotifyController();
    }
    
    private waitForSpotifyController() {
      document.addEventListener('spotify:ready', (event: Event) => {
        const customEvent = event as CustomEvent;
        this.spotifyController = customEvent.detail.controller;
      });
    }
    
    private setupEventListeners() {
      // Listen for navigation events from NavigationControls component
      this.container.addEventListener('carousel:navigate', this.handleNavigationEvent.bind(this) as EventListener);
      
      // Listen for pagination events from PaginationIndicator component
      this.container.addEventListener('pagination:navigate', this.handlePaginationEvent.bind(this) as EventListener);
      
      // Keyboard navigation for the carousel container
      this.container.addEventListener('keydown', this.handleKeyboard.bind(this));
    }
    
    private handleNavigationEvent(event: Event) {
      const customEvent = event as CustomEvent;
      const { direction } = customEvent.detail;
      
      if (direction === 'next' && this.currentIndex < this.totalPlaylists - 1) {
        this.navigateToIndex(this.currentIndex + 1);
      } else if (direction === 'previous' && this.currentIndex > 0) {
        this.navigateToIndex(this.currentIndex - 1);
      }
    }
    
    private handlePaginationEvent(event: Event) {
      const customEvent = event as CustomEvent;
      const { index } = customEvent.detail;
      
      this.navigateToIndex(index);
    }
    
    private handleKeyboard(event: KeyboardEvent) {
      if (event.target !== this.container && !this.container.contains(event.target as Node)) {
        return;
      }
      
      switch (event.key) {
        case 'ArrowLeft':
          event.preventDefault();
          if (this.currentIndex > 0) {
            this.navigateToIndex(this.currentIndex - 1);
          }
          break;
        case 'ArrowRight':
          event.preventDefault();
          if (this.currentIndex < this.totalPlaylists - 1) {
            this.navigateToIndex(this.currentIndex + 1);
          }
          break;
      }
    }
    
    private navigateToIndex(index: number) {
      if (index === this.currentIndex || index < 0 || index >= this.totalPlaylists) {
        return;
      }
      
      // Immediately dispatch stop event BEFORE changing playlist
      const stopEvent = new CustomEvent('carousel:navigate', {
        detail: { 
          direction: index > this.currentIndex ? 'next' : 'previous',
          fromIndex: this.currentIndex,
          toIndex: index
        },
        bubbles: true
      });
      document.dispatchEvent(stopEvent);
      
      this.currentIndex = index;
      this.loadPlaylist(index);
      
      // Update UI immediately
      this.updateNavigationState();
      this.updatePaginationState();
      this.updateAccessibility();
    }
    
    private loadPlaylist(index: number) {
      const playlist = this.playlists[index];
      if (!playlist) return;
      
      // Extract URI from embed URL
      const uri = this.extractUri(playlist.embedUrl);
      
      if (this.spotifyController && uri) {
        this.spotifyController.loadUri(uri);
      }
    }
    
    private extractUri(embedUrl: string): string {
      const match = embedUrl.match(/\/embed\/(track|album|playlist|episode|show)\/([a-zA-Z0-9]+)/);
      if (match) {
        return `spotify:${match[1]}:${match[2]}`;
      }
      return '';
    }
    
    private updateNavigationState() {
      // Update NavigationControls component state
      const navigationControls = this.container.querySelector('.navigation-controls');
      if (navigationControls && (window as any).NavigationControlsHandler) {
        const handler = (navigationControls as any).navigationHandler;
        if (handler && handler.updateButtonStates) {
          handler.updateButtonStates(this.currentIndex, this.totalPlaylists);
        }
      }
    }
    
    private updatePaginationState() {
      // Update PaginationIndicator component state
      const paginationIndicator = this.container.querySelector('[data-pagination-indicator]');
      if (paginationIndicator && (paginationIndicator as any).paginationHandler) {
        const handler = (paginationIndicator as any).paginationHandler;
        handler.updateState(this.currentIndex);
      }
    }
    
    private updateAccessibility() {
      if (this.liveRegion) {
        const currentPlaylist = this.playlists[this.currentIndex];
        const playlistTitle = currentPlaylist?.title || `Playlist ${this.currentIndex + 1}`;
        
        this.liveRegion.textContent = `Showing playlist ${this.currentIndex + 1} of ${this.totalPlaylists}: ${playlistTitle}`;
      }
    }
  }
  
  // Initialize carousels when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    const carousels = document.querySelectorAll('.spotify-playlist-carousel');
    carousels.forEach(carousel => {
      new SpotifyPlaylistCarousel(carousel as HTMLElement);
    });
  });
</script>