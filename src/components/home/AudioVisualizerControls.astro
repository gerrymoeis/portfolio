---
/**
 * AudioVisualizerControls - UX-friendly visualizer controls
 * Features: 
 * - First-time landing overlay
 * - Concise permission modal
 * - Start button (bottom right)
 * - Toast notifications (top right)
 */

export interface Props {
  /** Additional CSS class names */
  className?: string;
}

const { className = '' } = Astro.props;
---

<!-- First-Time Landing Overlay -->
<div class="visualizer-landing" id="visualizerLanding" style="display: none;">
  <div class="visualizer-landing__backdrop"></div>
  <div class="visualizer-landing__content">
    <div class="visualizer-landing__left">
      <h2 class="visualizer-landing__title" data-bilingual="visualizer-title">
        <span data-lang="en">Enhanced Audio Experience</span>
        <span data-lang="id">Pengalaman Audio yang Ditingkatkan</span>
      </h2>
      <p class="visualizer-landing__description" data-bilingual="visualizer-description">
        <span data-lang="en">
          This site features a <span class="visualizer-landing__highlight">real-time music visualizer</span> that syncs with <span class="visualizer-landing__highlight">audio playback</span>. 
          To enable it, we'll need permission to listen to this tab's audio.
        </span>
        <span data-lang="id">
          Situs ini memiliki <span class="visualizer-landing__highlight">visualizer musik real-time</span> yang sinkron dengan <span class="visualizer-landing__highlight">pemutaran audio</span>. 
          Untuk mengaktifkannya, kami memerlukan izin untuk mendengarkan audio tab ini.
        </span>
      </p>
      <p class="visualizer-landing__privacy" data-bilingual="visualizer-privacy">
        <span data-lang="en">
          <span class="visualizer-landing__privacy-highlight">No recording</span> or <span class="visualizer-landing__privacy-highlight">data collection</span>. Audio is analyzed in real-time only.
        </span>
        <span data-lang="id">
          <span class="visualizer-landing__privacy-highlight">Tidak ada rekaman</span> atau <span class="visualizer-landing__privacy-highlight">pengumpulan data</span>. Audio hanya dianalisis secara real-time.
        </span>
      </p>
    </div>
    <div class="visualizer-landing__right">
      <button class="visualizer-landing__button visualizer-landing__button--secondary" id="landingSkip" data-bilingual="skip-button">
        <span data-lang="en">Skip for Now</span>
        <span data-lang="id">Lewati Sekarang</span>
      </button>
      <button class="visualizer-landing__button visualizer-landing__button--primary" id="landingEnable" data-bilingual="enable-button">
        <span data-lang="en">Enable Visualizer</span>
        <span data-lang="id">Aktifkan Visualizer</span>
      </button>
    </div>
  </div>
</div>

<!-- Start Visualizer Button (bottom right, shown when stopped) -->
<button class="visualizer-start-btn" id="visualizerStartBtn" style="display: none;" data-bilingual="start-button">
  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
    <path d="M4 2l11 7-11 7V2z" fill="currentColor"/>
  </svg>
  <span data-lang="en">Start Visualizer</span>
  <span data-lang="id">Mulai Visualizer</span>
</button>

<!-- Toast Notification (top right) -->
<div class={`visualizer-toast ${className}`} id="visualizerToast" data-visualizer-toast style="display: none;">
  <div class="visualizer-toast__content">
    <span class="visualizer-toast__text" id="toastText">Waiting for music...</span>
    <button class="visualizer-toast__close" id="toastClose" aria-label="Close notification">
      <svg width="24" height="24" viewBox="0 0 16 16" fill="none">
        <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <div class="visualizer-toast__progress" id="toastProgress"></div>
</div>

<script>
  import { getTabAudioVisualizer } from '../../scripts/tabAudioVisualizer';
  import { getCurrentLanguage } from '../../scripts/language';

  // Local storage key for first visit
  const FIRST_VISIT_KEY = 'visualizer_first_visit_shown';

  // Bilingual messages
  const MESSAGES = {
    en: {
      // Status messages
      alreadyRunning: 'Visualizer is already running',
      requesting: 'Requesting tab audio capture... Please select "This Tab" and check "Share audio"',
      audioCaptured: 'Audio captured! Initializing visualizer...',
      visualizing: 'Visualizing! The visualizer is now synced with the audio.',
      screenSharingStopped: 'Screen sharing stopped by user',
      waiting: 'Waiting for music...',
      stopped: 'Visualizer stopped. Click "Start Visualizer" to begin again.',
      
      // Error messages
      permissionDenied: 'Permission denied. Please allow screen sharing and make sure to check "Share audio".',
      noAudioTrack: 'No audio track found! Make sure to check "Share audio" in the browser prompt.',
      noAudioSource: 'No audio source found. Make sure audio is playing.',
      failed: 'Failed to start visualizer: ',
    },
    id: {
      // Status messages
      alreadyRunning: 'Visualizer sudah berjalan',
      requesting: 'Meminta izin tangkapan audio tab... Silakan pilih "This Tab" dan centang "Share audio"',
      audioCaptured: 'Audio berhasil ditangkap! Menginisialisasi visualizer...',
      visualizing: 'Memvisualisasikan! Visualizer sekarang tersinkronisasi dengan audio.',
      screenSharingStopped: 'Berbagi layar dihentikan oleh pengguna',
      waiting: 'Menunggu musik...',
      stopped: 'Visualizer dihentikan. Klik "Mulai Visualizer" untuk memulai lagi.',
      
      // Error messages
      permissionDenied: 'Izin ditolak. Harap izinkan berbagi layar dan pastikan untuk mencentang "Share audio".',
      noAudioTrack: 'Track audio tidak ditemukan! Pastikan untuk mencentang "Share audio" di prompt browser.',
      noAudioSource: 'Sumber audio tidak ditemukan. Pastikan audio sedang diputar.',
      failed: 'Gagal memulai visualizer: ',
    }
  };

  /**
   * Get translated message using existing i18n system
   */
  function getMessage(key: keyof typeof MESSAGES.en): string {
    const lang = getCurrentLanguage();
    return MESSAGES[lang][key];
  }

  // Toast notification manager
  class ToastManager {
    private toast: HTMLElement;
    private toastText: HTMLElement;
    private toastProgress: HTMLElement;
    private closeBtn: HTMLElement;
    private autoHideTimer: number | null = null;
    private progressTimer: number | null = null;
    private isVisible: boolean = false;
    private currentMessageKey: keyof typeof MESSAGES.en | undefined = undefined;
    private currentType: 'info' | 'success' | 'error' = 'info';

    constructor() {
      this.toast = document.getElementById('visualizerToast') as HTMLElement;
      this.toastText = document.getElementById('toastText') as HTMLElement;
      this.toastProgress = document.getElementById('toastProgress') as HTMLElement;
      this.closeBtn = document.getElementById('toastClose') as HTMLElement;

      this.init();
    }

    private init(): void {
      this.closeBtn.addEventListener('click', () => {
        this.hide();
      });
      
      // Listen for language changes to update visible toast
      window.addEventListener('languagechange', () => {
        if (this.isVisible && this.currentMessageKey) {
          this.toastText.textContent = getMessage(this.currentMessageKey);
        }
      });
    }

    public show(message: string, type: 'info' | 'success' | 'error', duration: number = 5000, messageKey?: keyof typeof MESSAGES.en): void {
      this.toastText.textContent = message;
      this.currentMessageKey = messageKey;
      this.currentType = type;
      this.toast.className = `visualizer-toast visualizer-toast--${type} visualizer-toast--visible`;
      this.toast.style.display = 'block';
      this.isVisible = true;

      this.clearTimers();
      this.toastProgress.style.width = '100%';
      this.startProgress(duration);

      this.autoHideTimer = window.setTimeout(() => {
        this.hide();
      }, duration);
    }

    private startProgress(duration: number): void {
      const startTime = Date.now();
      
      const updateProgress = () => {
        if (!this.isVisible) return;

        const elapsed = Date.now() - startTime;
        const progress = Math.max(0, 100 - (elapsed / duration) * 100);
        this.toastProgress.style.width = `${progress}%`;

        if (progress > 0) {
          this.progressTimer = window.requestAnimationFrame(updateProgress);
        }
      };

      updateProgress();
    }

    public hide(): void {
      this.toast.classList.remove('visualizer-toast--visible');
      this.isVisible = false;
      
      setTimeout(() => {
        if (!this.isVisible) {
          this.toast.style.display = 'none';
        }
      }, 300);

      this.clearTimers();
    }

    private clearTimers(): void {
      if (this.autoHideTimer) {
        clearTimeout(this.autoHideTimer);
        this.autoHideTimer = null;
      }
      if (this.progressTimer) {
        cancelAnimationFrame(this.progressTimer);
        this.progressTimer = null;
      }
    }
  }

  // Landing overlay manager
  class LandingManager {
    private landing: HTMLElement;
    private skipBtn: HTMLElement;
    private enableBtn: HTMLElement;
    private onEnableCallback: (() => void) | null = null;
    private onSkipCallback: (() => void) | null = null;

    constructor() {
      this.landing = document.getElementById('visualizerLanding') as HTMLElement;
      this.skipBtn = document.getElementById('landingSkip') as HTMLElement;
      this.enableBtn = document.getElementById('landingEnable') as HTMLElement;

      this.init();
    }

    private init(): void {
      this.skipBtn.addEventListener('click', () => {
        this.hide();
        if (this.onSkipCallback) {
          this.onSkipCallback();
        }
      });
      
      this.enableBtn.addEventListener('click', () => {
        this.hide();
        if (this.onEnableCallback) {
          this.onEnableCallback();
        }
      });

      // Close on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isVisible()) {
          this.skipBtn.click();
        }
      });
    }

    public show(onEnable: () => void, onSkip: () => void): void {
      this.onEnableCallback = onEnable;
      this.onSkipCallback = onSkip;
      this.landing.style.display = 'flex';
      
      requestAnimationFrame(() => {
        this.landing.classList.add('visualizer-landing--visible');
      });

      document.body.style.overflow = 'hidden';
    }

    public hide(): void {
      this.landing.classList.remove('visualizer-landing--visible');
      
      setTimeout(() => {
        this.landing.style.display = 'none';
        document.body.style.overflow = '';
      }, 300);

      // Mark as shown
      localStorage.setItem(FIRST_VISIT_KEY, 'true');
    }

    public isVisible(): boolean {
      return this.landing.style.display === 'flex';
    }

    public hasBeenShown(): boolean {
      return localStorage.getItem(FIRST_VISIT_KEY) === 'true';
    }
  }

  // Start button manager
  class StartButtonManager {
    private button: HTMLElement;
    private onClick: (() => void) | null = null;

    constructor() {
      this.button = document.getElementById('visualizerStartBtn') as HTMLElement;
      this.init();
    }

    private init(): void {
      this.button.addEventListener('click', () => {
        if (this.onClick) {
          this.onClick();
        }
      });
    }

    public show(onClick: () => void): void {
      this.onClick = onClick;
      this.button.style.display = 'flex';
    }

    public hide(): void {
      this.button.style.display = 'none';
    }
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    const toastManager = new ToastManager();
    const landingManager = new LandingManager();
    const startButtonManager = new StartButtonManager();
    const visualizer = getTabAudioVisualizer();

    // Setup status callback
    visualizer.setStatusCallback((message: string, type: 'info' | 'success' | 'error') => {
      // Translate message to current language and get message key
      let translatedMessage = message;
      let messageKey: keyof typeof MESSAGES.en | undefined = undefined;
      
      // Map English messages to translation keys
      if (message.includes('already running')) {
        messageKey = 'alreadyRunning';
        translatedMessage = getMessage('alreadyRunning');
      } else if (message.includes('Requesting tab audio capture')) {
        messageKey = 'requesting';
        translatedMessage = getMessage('requesting');
      } else if (message.includes('Audio captured')) {
        messageKey = 'audioCaptured';
        translatedMessage = getMessage('audioCaptured');
      } else if (message.includes('Visualizing!')) {
        messageKey = 'visualizing';
        translatedMessage = getMessage('visualizing');
      } else if (message.includes('Screen sharing stopped')) {
        messageKey = 'screenSharingStopped';
        translatedMessage = getMessage('screenSharingStopped');
      } else if (message.includes('Waiting for music')) {
        messageKey = 'waiting';
        translatedMessage = getMessage('waiting');
      } else if (message.includes('stopped')) {
        messageKey = 'stopped';
        translatedMessage = getMessage('stopped');
      } else if (message.includes('Permission denied')) {
        messageKey = 'permissionDenied';
        translatedMessage = getMessage('permissionDenied');
      } else if (message.includes('No audio track found')) {
        messageKey = 'noAudioTrack';
        translatedMessage = getMessage('noAudioTrack');
      } else if (message.includes('No audio source')) {
        messageKey = 'noAudioSource';
        translatedMessage = getMessage('noAudioSource');
      } else if (message.includes('Failed to start visualizer')) {
        // For "Failed" messages, we keep the dynamic error part in English
        messageKey = 'failed';
        const errorPart = message.replace('Failed to start visualizer: ', '');
        translatedMessage = getMessage('failed') + errorPart;
      }
      
      const duration = type === 'error' ? 7000 : type === 'success' ? 4000 : 5000;
      toastManager.show(translatedMessage, type, duration, messageKey);

      // Show start button when stopped
      if (message.includes('stopped') || message.includes('denied') || message.includes('Failed')) {
        startButtonManager.show(() => startVisualizer());
      }
    });

    /**
     * Start the visualizer
     */
    async function startVisualizer(): Promise<void> {
      startButtonManager.hide();
      
      try {
        await visualizer.start();
      } catch (error) {
        console.error('Failed to start visualizer:', error);
        startButtonManager.show(() => startVisualizer());
      }
    }

    /**
     * Detect SoundCloud playback
     */
    function detectSoundCloudPlayback(): boolean {
      const iframes = document.querySelectorAll('iframe');
      for (const iframe of Array.from(iframes)) {
        if (iframe.src && iframe.src.includes('soundcloud.com')) {
          return true;
        }
      }
      return false;
    }

    /**
     * Check if should show landing overlay
     */
    function checkFirstVisit(): void {
      const hasSoundCloud = detectSoundCloudPlayback();
      
      if (!hasSoundCloud) {
        // No SoundCloud, don't show anything
        return;
      }

      if (!landingManager.hasBeenShown()) {
        // First visit - show landing overlay
        setTimeout(() => {
          landingManager.show(
            // On enable
            () => {
              startVisualizer();
            },
            // On skip
            () => {
              startButtonManager.show(() => startVisualizer());
            }
          );
        }, 1000); // Small delay after page load
      } else {
        // Not first visit - show start button
        startButtonManager.show(() => startVisualizer());
      }
    }

    // Check on page load
    if (document.readyState === 'complete') {
      checkFirstVisit();
    } else {
      window.addEventListener('load', () => {
        checkFirstVisit();
      });
    }
  });
</script>

<style>
  /* Landing Overlay Styles */
  .visualizer-landing {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    opacity: 0;
    transition: opacity 0.3s var(--ease-out);
  }

  .visualizer-landing--visible {
    opacity: 1;
  }

  .visualizer-landing__backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(var(--blur-backdrop-medium));
    -webkit-backdrop-filter: blur(var(--blur-backdrop-medium));
  }
  
  /* Light theme backdrop - lighter overlay */
  :global([data-theme="light"]) .visualizer-landing__backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  .visualizer-landing__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    width: 100%;
    display: flex;
    gap: var(--space-6);
    background: var(--color-surface-elevated);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    border: var(--panel-border-width) var(--panel-border-style) var(--color-border-accent);
    transform: scale(0.95);
    transition: transform var(--duration-medium) var(--ease-out);
  }
  
  /* Dark theme - golden glow */
  :global(html:not([data-theme="light"])) .visualizer-landing__content {
    box-shadow: 
      var(--glow-strong) var(--color-shadow-accent),
      0 var(--space-5) var(--space-12) var(--color-shadow-strong);
  }
  
  /* Light theme - red-orange glow */
  :global([data-theme="light"]) .visualizer-landing__content {
    box-shadow: 
      var(--glow-strong) var(--color-shadow-accent),
      0 var(--space-5) var(--space-12) var(--color-shadow-medium);
  }

  .visualizer-landing--visible .visualizer-landing__content {
    transform: scale(1);
  }

  .visualizer-landing__left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .visualizer-landing__title {
    font-size: var(--font-size-2xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.2;
  }
  
  /* Hide inactive language */
  .visualizer-landing__title span[data-lang] {
    display: none;
  }
  
  /* Show active language */
  :global(html[lang="en"]) .visualizer-landing__title span[data-lang="en"],
  :global(html[lang="id"]) .visualizer-landing__title span[data-lang="id"] {
    display: inline;
  }

  .visualizer-landing__description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  
  /* Hide inactive language */
  .visualizer-landing__description span[data-lang] {
    display: none;
  }
  
  /* Show active language */
  :global(html[lang="en"]) .visualizer-landing__description span[data-lang="en"],
  :global(html[lang="id"]) .visualizer-landing__description span[data-lang="id"] {
    display: inline;
  }

  .visualizer-landing__highlight {
    color: var(--color-accent-primary);
    font-weight: 600;
  }
  
  /* Dark theme - add glow effect */
  :global(html:not([data-theme="light"])) .visualizer-landing__highlight {
    text-shadow: var(--glow-subtle) var(--color-shadow-accent);
  }
  
  /* Light theme - no glow */
  :global([data-theme="light"]) .visualizer-landing__highlight {
    text-shadow: none;
  }

  .visualizer-landing__privacy {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    line-height: 1.5;
    margin: 0;
    padding-top: var(--space-2);
    border-top: var(--panel-border-width) var(--panel-border-style) var(--color-border-light);
  }
  
  /* Hide inactive language */
  .visualizer-landing__privacy span[data-lang] {
    display: none;
  }
  
  /* Show active language */
  :global(html[lang="en"]) .visualizer-landing__privacy span[data-lang="en"],
  :global(html[lang="id"]) .visualizer-landing__privacy span[data-lang="id"] {
    display: inline;
  }

  .visualizer-landing__privacy-highlight {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .visualizer-landing__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    justify-content: center;
    min-width: 160px;
  }

  .visualizer-landing__button {
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 600;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    white-space: nowrap;
  }
  
  /* Hide inactive language for buttons */
  .visualizer-landing__button span[data-lang] {
    display: none;
  }
  
  /* Show active language for buttons */
  :global(html[lang="en"]) .visualizer-landing__button span[data-lang="en"],
  :global(html[lang="id"]) .visualizer-landing__button span[data-lang="id"] {
    display: inline;
  }

  .visualizer-landing__button--secondary {
    background: var(--color-surface-light);
    color: var(--color-text-secondary);
    border-color: var(--color-border-medium);
  }

  .visualizer-landing__button--secondary:hover {
    color: var(--color-text-primary);
    transform: var(--transform-hover-lift);
  }
  
  /* Dark theme secondary button - golden yellow glowing border */
  :global(html:not([data-theme="light"])) .visualizer-landing__button--secondary {
    background: var(--color-surface-light);
    border-color: var(--color-border-medium);
  }
  
  :global(html:not([data-theme="light"])) .visualizer-landing__button--secondary:hover {
    background: rgba(246, 224, 94, 0.1);
    border-color: rgba(246, 224, 94, 0.8);
    box-shadow: 
      0 0 20px rgba(246, 224, 94, 0.4),
      inset 0 0 10px rgba(246, 224, 94, 0.08);
  }
  
  /* Light theme secondary button - red-orange glowing border */
  :global([data-theme="light"]) .visualizer-landing__button--secondary {
    background: rgba(255, 85, 0, 0.08);
    border-color: rgba(255, 85, 0, 0.3);
  }
  
  :global([data-theme="light"]) .visualizer-landing__button--secondary:hover {
    background: rgba(255, 85, 0, 0.15);
    border-color: rgba(255, 85, 0, 0.8);
    box-shadow: 
      0 0 20px rgba(255, 85, 0, 0.4),
      inset 0 0 10px rgba(255, 85, 0, 0.08);
  }

  .visualizer-landing__button--primary {
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
    font-weight: 600;
  }
  
  /* Dark theme primary button */
  :global(html:not([data-theme="light"])) .visualizer-landing__button--primary {
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
    box-shadow: var(--glow-medium) var(--color-shadow-accent);
  }

  :global(html:not([data-theme="light"])) .visualizer-landing__button--primary:hover {
    background: var(--color-bg-dark);
    color: #f6e05e;
    border-color: #f6e05e;
    box-shadow: 
      0 0 40px rgba(246, 224, 94, 0.8),
      0 0 20px rgba(246, 224, 94, 0.6),
      inset 0 0 20px rgba(246, 224, 94, 0.1);
    text-shadow: 0 0 10px rgba(246, 224, 94, 0.8);
    transform: var(--transform-hover-lift-strong);
  }
  
  /* Light theme primary button */
  :global([data-theme="light"]) .visualizer-landing__button--primary {
    background: #ff5500;
    color: #ffffff;
    box-shadow: var(--glow-medium) var(--color-shadow-accent);
  }
  
  :global([data-theme="light"]) .visualizer-landing__button--primary:hover {
    background: #ffffff;
    color: #ff5500;
    border-color: #ff5500;
    box-shadow: 
      0 0 40px rgba(255, 85, 0, 0.8),
      0 0 20px rgba(255, 85, 0, 0.6),
      inset 0 0 20px rgba(255, 85, 0, 0.1);
    text-shadow: 0 0 10px rgba(255, 85, 0, 0.8);
    transform: var(--transform-hover-lift-strong);
  }

  .visualizer-landing__button--primary:active {
    transform: translateY(0);
  }

  /* Start Button (Bottom Right) */
  .visualizer-start-btn {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
    font-size: var(--font-size-sm);
    font-weight: 600;
    border: 2px solid transparent;
    border-radius: var(--radius-full);
    cursor: pointer;
