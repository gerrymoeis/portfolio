---
/**
 * AudioVisualizer - Audio visualizer that syncs with SoundCloud player
 * Positioned at the bottom of the home page with HD-2D styling
 * Provides organic-looking animations that respond to playback state
 */

export interface Props {
  /** Height of the visualizer container in pixels */
  height?: number;
}

const { 
  height = 180 // Default height in pixels
} = Astro.props;

// Calculate glow height (should be taller than visualizer for effect)
const glowHeight = Math.max(height * 2.2, 400);
---

<div 
  class="audio-visualizer" 
  data-visualizer-container
  style={`--visualizer-height: ${height}px; --glow-height: ${glowHeight}px;`}
>
  <!-- Canvas for visualization -->
  <canvas 
    id="visualizer-canvas" 
    data-visualizer-canvas
  ></canvas>
  
  <!-- HD-2D atmospheric glow effect -->
  <div class="audio-visualizer__glow" aria-hidden="true"></div>
</div>

<script>
  // Audio Visualizer - Canvas-based rendering
  // Visualization logic is handled by TabAudioVisualizer (tabAudioVisualizer.ts)
  // This component just provides the canvas element
  
  console.log('✅ Audio Visualizer canvas ready');
</script>

<style>
  .audio-visualizer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--visualizer-height, 180px); /* Use CSS variable with fallback */
    z-index: 999;
    pointer-events: none;
    overflow: hidden;
  }
  
  canvas[data-visualizer-canvas] {
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    margin: 0;
    padding: 0;
  }
  
  .audio-visualizer__glow {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--glow-height, 400px); /* Use CSS variable with fallback */
    background: radial-gradient(
      ellipse 150% 100% at center bottom,
      rgba(246, 224, 94, 0.02) 0%,
      rgba(237, 137, 54, 0.01) 20%,
      rgba(139, 149, 109, 0.005) 40%,
      transparent 60%
    );
    z-index: 1;
    opacity: 0.3;
    filter: blur(8px);
  }
  
  .audio-visualizer--playing .audio-visualizer__glow {
    animation: glow-pulse 8s ease-in-out infinite alternate;
  }
  
  .audio-visualizer--paused .audio-visualizer__glow {
    opacity: 0 !important;
    animation: none !important;
    transition: opacity 1.5s ease-out !important;
  }
  
  @keyframes glow-pulse {
    0% {
      opacity: 0.2;
      transform: scaleY(0.8) scaleX(1.2);
    }
    100% {
      opacity: 0.4;
      transform: scaleY(1.0) scaleX(1.5);
    }
  }
  
  /* Responsive: Scale down on smaller screens */
  @media (max-width: var(--breakpoint-lg)) {
    .audio-visualizer {
      /* Scale to 80% of configured height, min 80px, max 100px */
      height: clamp(80px, calc(var(--visualizer-height, 180px) * 0.8), 100px);
    }
    
    .audio-visualizer__glow {
      height: calc(var(--glow-height, 400px) * 0.875); /* 87.5% of glow height */
    }
  }
  
  @media (max-width: var(--breakpoint-md)) {
    .audio-visualizer {
      /* Scale to 60% of configured height, min 60px, max 80px */
      height: clamp(60px, calc(var(--visualizer-height, 180px) * 0.6), 80px);
    }
    
    .audio-visualizer__glow {
      height: calc(var(--glow-height, 400px) * 0.75); /* 75% of glow height */
    }
  }
  
  @media (max-width: var(--breakpoint-sm)) {
    .audio-visualizer {
      /* Scale to 40% of configured height, min 40px, max 60px */
      height: clamp(40px, calc(var(--visualizer-height, 180px) * 0.4), 60px);
    }
    
    .audio-visualizer__glow {
      height: calc(var(--glow-height, 400px) * 0.625); /* 62.5% of glow height */
    }
  }
  
  @media (prefers-reduced-motion: reduce) {
    .audio-visualizer__glow {
      animation: none !important;
    }
  }
  
  @media (prefers-contrast: high) {
    .audio-visualizer__glow {
      display: none;
    }
  }
</style>
