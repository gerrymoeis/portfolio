---
/**
 * Hero - Home page hero section
 * Displays main title, subtitle, and description
 * Updated for minimalist design with serif headings
 * 
 * Props:
 * - title: Main hero title (required)
 * - subtitle: Hero subtitle (required)
 * - description: Hero description text (required)
 */

interface Props {
  title: string;
  subtitle: string;
  description: string;
}

const { title, subtitle, description } = Astro.props;
---

<div class="hero">
  <h1 class="hero__title">{title}</h1>
  <p class="hero__subtitle">{subtitle}</p>
  <p class="hero__description">{description}</p>
</div>

<style>
  .hero {
    text-align: center;
    max-width: var(--hero-max-width);
    margin: 0 auto;
  }

  .hero__title {
    font-family: var(--font-display); /* Serif for headings */
    font-size: var(--text-5xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-4) 0;
    letter-spacing: clamp(-0.03em, -0.02em + -0.01vw, -0.02em);
  }

  .hero__subtitle {
    font-family: var(--font-body); /* Sans-serif for body */
    font-size: var(--text-xl);
    font-weight: var(--weight-medium);
    color: var(--color-accent-primary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-6) 0;
  }

  .hero__description {
    font-family: var(--font-body); /* Sans-serif for body */
    font-size: var(--text-lg);
    font-weight: var(--weight-normal);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: var(--hero-description-max-width);
    margin-left: auto;
    margin-right: auto;
  }

  /* Responsive typography - Mobile first approach */
  
  /* Extra small devices */
  @media (max-width: var(--breakpoint-xs)) {
    .hero__title {
      font-size: var(--text-3xl);
      margin-bottom: var(--space-3);
    }

    .hero__subtitle {
      font-size: var(--text-base);
      margin-bottom: var(--space-4);
    }

    .hero__description {
      font-size: var(--text-sm);
    }
  }

  /* Small devices */
  @media (min-width: var(--breakpoint-xs)) and (max-width: var(--breakpoint-sm)) {
    .hero__title {
      font-size: var(--text-4xl);
      margin-bottom: var(--space-3);
    }

    .hero__subtitle {
      font-size: var(--text-lg);
      margin-bottom: var(--space-5);
    }

    .hero__description {
      font-size: var(--text-base);
    }
  }

  /* Medium devices */
  @media (min-width: var(--breakpoint-sm)) and (max-width: var(--breakpoint-lg)) {
    .hero__title {
      font-size: var(--text-4xl);
    }

    .hero__subtitle {
      font-size: var(--text-lg);
    }

    .hero__description {
      font-size: var(--text-base);
    }
  }

  /* Large devices and up - use fluid scaling */
  @media (min-width: var(--breakpoint-lg)) {
    .hero__title {
      font-size: var(--text-5xl);
    }

    .hero__subtitle {
      font-size: var(--text-xl);
    }

    .hero__description {
      font-size: var(--text-lg);
    }
  }

  /* Ultra-wide screens - prevent text from becoming too large */
  @media (min-width: var(--breakpoint-2xl)) {
    .hero__title {
      font-size: clamp(var(--text-5xl), 4vw, var(--text-6xl));
    }
  }

  /* Landscape orientation on mobile - adjust spacing */
  @media (max-height: 600px) and (orientation: landscape) {
    .hero__title {
      margin-bottom: var(--space-2);
    }

    .hero__subtitle {
      margin-bottom: var(--space-3);
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .hero__title {
      color: var(--color-text-primary);
      text-shadow: none;
    }

    .hero__subtitle {
      color: var(--color-accent-primary);
    }

    .hero__description {
      color: var(--color-text-secondary);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__subtitle,
    .hero__description {
      transition: none;
    }
  }
</style>
