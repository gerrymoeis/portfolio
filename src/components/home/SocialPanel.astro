---
/**
 * SocialPanel - Social media links panel with CV download
 * Updated for minimalist design with bilingual support
 * 
 * Props:
 * - social: Array of social link objects with name, url, and icon
 */

import Icon from '../ui/Icon.astro';

interface SocialLink {
  name: string;
  url: string;
  icon: string;
}

interface Props {
  social: SocialLink[];
}

const { social } = Astro.props;

// Filter out LinkedIn
const filteredSocial = social.filter(link => link.name.toLowerCase() !== 'linkedin');
---

<div class="social-panel">
  <h2 class="social-panel__title" data-bilingual="social-title">
    <span data-lang="en">Connect</span>
    <span data-lang="id">Terhubung</span>
  </h2>
  <ul class="social-panel__list">
    {filteredSocial.map((link) => (
      <li class="social-panel__item">
        <a 
          href={link.url} 
          class="social-panel__link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Visit ${link.name}`}
        >
          <Icon name={link.icon} class="social-panel__icon" />
          <span class="social-panel__name">{link.name}</span>
        </a>
      </li>
    ))}
  </ul>
  
  <!-- Download CV Button -->
  <div class="social-panel__cv-section">
    <a 
      href="/cv.pdf" 
      class="social-panel__cv-button"
      download
      aria-label="Download CV"
      data-bilingual="cv-button"
    >
      <Icon name="download" class="social-panel__cv-icon" />
      <span data-lang="en">Download my CV</span>
      <span data-lang="id">Unduh CV saya</span>
    </a>
  </div>
</div>

<style>
  .social-panel {
    width: 100%;
  }

  .social-panel__title {
    font-family: var(--font-display); /* Serif for headings */
    font-size: var(--text-2xl); /* Proper heading hierarchy - 20.8-24px */
    font-weight: var(--weight-bold); /* Stronger weight for headings */
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0; /* More space below heading */
    text-align: center;
    line-height: var(--leading-tight);
  }
  
  /* Hide inactive language */
  .social-panel__title span[data-lang] {
    display: none;
  }
  
  /* Show active language */
  :global(html[lang="en"]) .social-panel__title span[data-lang="en"],
  :global(html[lang="id"]) .social-panel__title span[data-lang="id"] {
    display: inline;
  }

  .social-panel__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .social-panel__item {
    margin: 0;
  }

  .social-panel__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-social);
    transition: 
      background-color var(--duration-medium) ease,
      color var(--duration-medium) ease,
      transform var(--duration-fast) ease;
  }

  .social-panel__link:hover {
    background-color: var(--color-social-hover-bg);
    color: var(--color-contrast-high);
    transform: var(--transform-hover-lift);
  }

  .social-panel__link:focus-visible {
    outline: var(--focus-outline-width) var(--focus-outline-style) var(--focus-outline-color);
    outline-offset: var(--focus-outline-offset);
  }

  .social-panel__icon {
    font-size: var(--text-xl);
    line-height: 1;
    flex-shrink: 0;
  }

  .social-panel__name {
    font-family: var(--font-body); /* Sans-serif for body */
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
  }
  
  /* CV Download Section */
  .social-panel__cv-section {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-medium);
    display: flex;
    justify-content: center;
  }
  
  .social-panel__cv-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    border-radius: var(--radius-full);
    border: 2px solid transparent;
    transition: all var(--duration-medium) ease;
    box-shadow: 0 0 20px rgba(246, 224, 94, 0.3);
  }
  
  /* Dark theme CV button */
  :global(html:not([data-theme="light"])) .social-panel__cv-button {
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
  }
  
  :global(html:not([data-theme="light"])) .social-panel__cv-button:hover {
    background: var(--color-bg-dark);
    color: #f6e05e;
    border-color: #f6e05e;
    box-shadow: 
      0 0 40px rgba(246, 224, 94, 0.8),
      0 0 20px rgba(246, 224, 94, 0.6),
      inset 0 0 20px rgba(246, 224, 94, 0.1);
    text-shadow: 0 0 10px rgba(246, 224, 94, 0.8);
    transform: translateY(-2px);
  }
  
  /* Light theme CV button */
  :global([data-theme="light"]) .social-panel__cv-button {
    background: #ff5500;
    color: #ffffff;
    box-shadow: 0 0 20px rgba(255, 85, 0, 0.3);
  }
  
  :global([data-theme="light"]) .social-panel__cv-button:hover {
    background: #ffffff;
    color: #ff5500;
    border-color: #ff5500;
    box-shadow: 
      0 0 40px rgba(255, 85, 0, 0.8),
      0 0 20px rgba(255, 85, 0, 0.6),
      inset 0 0 20px rgba(255, 85, 0, 0.1);
    text-shadow: 0 0 10px rgba(255, 85, 0, 0.8);
    transform: translateY(-2px);
  }
  
  .social-panel__cv-button:focus-visible {
    outline: var(--focus-outline-width) var(--focus-outline-style) var(--focus-outline-color);
    outline-offset: var(--focus-outline-offset);
  }
  
  .social-panel__cv-button:active {
    transform: translateY(0);
  }
  
  .social-panel__cv-icon {
    font-size: var(--text-lg);
    line-height: 1;
  }
  
  /* Hide inactive language for CV button */
  .social-panel__cv-button span[data-lang] {
    display: none;
  }
  
  /* Show active language for CV button */
  :global(html[lang="en"]) .social-panel__cv-button span[data-lang="en"],
  :global(html[lang="id"]) .social-panel__cv-button span[data-lang="id"] {
    display: inline;
  }

  /* Responsive adjustments - Mobile first approach */
  
  /* Extra small devices - stack vertically with smaller text */
  @media (max-width: var(--breakpoint-xs)) {
    .social-panel__title {
      font-size: var(--text-base);
      margin-bottom: var(--space-3);
    }

    .social-panel__list {
      gap: var(--space-2);
    }

    .social-panel__link {
      padding: var(--space-2);
      gap: var(--space-2);
    }

    .social-panel__icon {
      font-size: var(--text-lg);
    }

    .social-panel__name {
      font-size: var(--text-sm);
    }
    
    .social-panel__cv-section {
      margin-top: var(--space-4);
      padding-top: var(--space-4);
    }
    
    .social-panel__cv-button {
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-sm);
      gap: var(--space-1);
    }
    
    .social-panel__cv-icon {
      font-size: var(--text-base);
    }
  }

  /* Small devices - maintain vertical layout */
  @media (min-width: var(--breakpoint-xs)) and (max-width: var(--breakpoint-sm)) {
    .social-panel__list {
      gap: var(--space-3);
    }

    .social-panel__link {
      padding: var(--space-3);
    }
  }

  /* Medium devices - consider horizontal layout for wider containers */
  @media (min-width: var(--breakpoint-sm)) and (max-width: var(--breakpoint-md)) {
    .social-panel__list {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .social-panel__link {
      flex-direction: column;
      text-align: center;
      padding: var(--space-2);
      min-width: 80px;
    }

    .social-panel__name {
      font-size: var(--text-sm);
    }
  }

  /* Large devices - back to vertical for better readability */
  @media (min-width: var(--breakpoint-md)) {
    .social-panel__list {
      flex-direction: column;
      gap: var(--space-3);
    }

    .social-panel__link {
      flex-direction: row;
      text-align: left;
      padding: var(--space-3);
    }

    .social-panel__name {
      font-size: var(--text-base);
    }
  }

  /* Container-based responsive behavior */
  @container (max-width: 300px) {
    .social-panel__list {
      flex-direction: column;
      gap: var(--space-2);
    }

    .social-panel__link {
      flex-direction: row;
      padding: var(--space-2);
      gap: var(--space-2);
    }

    .social-panel__icon {
      font-size: var(--text-lg);
    }

    .social-panel__name {
      font-size: var(--text-sm);
    }
  }

  @container (min-width: 300px) and (max-width: 400px) {
    .social-panel__list {
      flex-direction: column;
      gap: var(--space-3);
    }
  }

  /* Landscape orientation on mobile - horizontal layout */
  @media (max-height: 600px) and (orientation: landscape) and (max-width: var(--breakpoint-md)) {
    .social-panel__list {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .social-panel__link {
      flex-direction: column;
      text-align: center;
      padding: var(--space-2);
      min-width: 70px;
    }

    .social-panel__name {
      font-size: var(--text-xs);
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .social-panel__link {
      border: 1px solid var(--color-border-medium);
    }

    .social-panel__link:hover {
      border-color: var(--color-accent-primary);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .social-panel__link {
      transition: none;
    }

    .social-panel__link:hover {
      transform: none;
    }
  }

  /* Touch device optimizations */
  @media (hover: none) and (pointer: coarse) {
    .social-panel__link {
      padding: var(--space-4);
      min-height: 44px; /* Minimum touch target size */
    }

    .social-panel__icon {
      font-size: var(--text-xl);
    }
  }
</style>
