---
/**
 * BlogList - Query and display all blog posts
 * Fetches all blog posts from the content collection and displays them as cards
 * Sorted by date (newest first)
 */

import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';

// Query all blog posts from the content collection
const allBlogs = await getCollection('blogs');

// Sort blogs by date (newest first)
const sortedBlogs = allBlogs.sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});
---

<section class="blog-list" aria-label="Blog posts">
  {sortedBlogs.length === 0 ? (
    <p class="blog-list__empty">No blog posts yet. Check back soon!</p>
  ) : (
    <div class="blog-list__grid" role="list">
      {sortedBlogs.map((blog) => (
        <BlogCard
          title={blog.data.title}
          date={blog.data.date}
          summary={blog.data.summary}
          slug={blog.slug}
          tags={blog.data.tags}
        />
      ))}
    </div>
  )}
</section>

<style>
  .blog-list {
    width: 100%;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--grid-margin);
  }

  .blog-list__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--grid-gap);
  }

  .blog-list__empty {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-tertiary);
    text-align: center;
    padding: var(--space-16) var(--space-6);
  }

  /* Responsive grid - Mobile first approach */
  
  /* Extra small devices - single column with tight spacing */
  @media (max-width: var(--breakpoint-xs)) {
    .blog-list {
      padding: var(--space-6) var(--space-3);
    }

    .blog-list__grid {
      gap: var(--space-4);
    }

    .blog-list__empty {
      font-size: var(--text-base);
      padding: var(--space-12) var(--space-4);
    }
  }

  /* Small devices - single column with comfortable spacing */
  @media (min-width: var(--breakpoint-xs)) and (max-width: var(--breakpoint-md)) {
    .blog-list {
      padding: var(--space-6) var(--space-4);
    }

    .blog-list__grid {
      gap: var(--space-6);
    }
  }

  /* Medium devices - consider two columns for wider screens */
  @media (min-width: var(--breakpoint-md)) and (max-width: var(--breakpoint-lg)) {
    .blog-list {
      padding: var(--space-8) var(--space-5);
    }

    .blog-list__grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--space-6);
    }
  }

  /* Large devices - two columns */
  @media (min-width: var(--breakpoint-lg)) and (max-width: var(--breakpoint-xl)) {
    .blog-list {
      padding: var(--space-8) var(--space-6);
    }

    .blog-list__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  /* Extra large devices - two columns with more spacing */
  @media (min-width: var(--breakpoint-xl)) {
    .blog-list {
      padding: var(--space-12) var(--space-8);
    }

    .blog-list__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  /* Ultra-wide screens - prevent over-expansion, consider three columns */
  @media (min-width: var(--breakpoint-2xl)) {
    .blog-list__grid {
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: var(--space-10);
    }
  }

  /* Landscape orientation on mobile - adjust spacing */
  @media (max-height: 600px) and (orientation: landscape) and (max-width: var(--breakpoint-lg)) {
    .blog-list {
      padding: var(--space-4) var(--space-4);
    }

    .blog-list__grid {
      gap: var(--space-4);
    }

    .blog-list__empty {
      padding: var(--space-8) var(--space-4);
    }
  }

  /* Container queries for adaptive behavior */
  @container (max-width: 400px) {
    .blog-list {
      padding: var(--space-6) var(--space-3);
    }

    .blog-list__grid {
      gap: var(--space-4);
    }
  }

  @container (min-width: 400px) and (max-width: 700px) {
    .blog-list {
      padding: var(--space-8) var(--space-4);
    }

    .blog-list__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  @container (min-width: 700px) and (max-width: 1000px) {
    .blog-list__grid {
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: var(--space-6);
    }
  }

  @container (min-width: 1000px) {
    .blog-list__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .blog-list__empty {
      color: var(--color-text-secondary);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .blog-list__grid {
      /* Ensure smooth layout without animations */
    }
  }
</style>
