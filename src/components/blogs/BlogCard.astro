---
/**
 * BlogCard - Individual blog preview card
 * Displays blog post metadata and summary with a link to the full post
 * 
 * Props:
 * - title: Blog post title
 * - date: Publication date
 * - summary: Brief description
 * - slug: URL slug for the blog post
 * - tags: Optional array of tags
 */

import ViewCounter from './ViewCounter.astro';

interface Props {
  title: string;
  date: Date;
  summary: string;
  slug: string;
  tags?: string[];
}

const { title, date, summary, slug, tags } = Astro.props;

// Format date for display (simple approach for build compatibility)
const months = ['January', 'February', 'March', 'April', 'May', 'June', 
                'July', 'August', 'September', 'October', 'November', 'December'];
const formattedDate = `${months[date.getMonth()]} ${date.getDate()}, ${date.getFullYear()}`;
---

<article class="blog-card" role="listitem">
  <a href={`/blogs/${slug}`} class="blog-card__link" aria-label={`Read article: ${title}`}>
    <div class="blog-card__header">
      <h2 class="blog-card__title">{title}</h2>
      <div class="blog-card__meta">
        <time class="blog-card__date" datetime={date.toISOString()}>
          {formattedDate}
        </time>
        <ViewCounter slug={slug} />
      </div>
    </div>
    
    <p class="blog-card__summary">{summary}</p>
    
    {tags && tags.length > 0 && (
      <div class="blog-card__tags" role="list" aria-label="Article tags">
        {tags.map(tag => (
          <span class="blog-card__tag" role="listitem">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .blog-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: 
      border-color var(--duration-medium) var(--ease-out),
      transform var(--duration-medium) var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  /* Subtle grain texture overlay */
  .blog-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/textures/grain.png');
    opacity: 0.03;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .blog-card:hover {
    border-color: var(--color-border-strong);
    transform: var(--transform-hover-lift-strong);
  }

  .blog-card__link {
    display: block;
    padding: var(--space-6);
    color: inherit;
    text-decoration: none;
    position: relative;
    z-index: 1;
  }

  .blog-card__link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .blog-card__header {
    margin-bottom: var(--space-4);
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .blog-card__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .blog-card:hover .blog-card__title {
    color: var(--color-accent-primary);
  }

  .blog-card__date {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
    color: var(--color-text-tertiary);
  }

  .blog-card__summary {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .blog-card__tag {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-accent-secondary);
    background-color: var(--color-social-hover-bg);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-tag);
    border: 1px solid var(--color-border);
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .blog-card {
      transition: none;
    }

    .blog-card:hover {
      transform: none;
    }

    .blog-card__title {
      transition: none;
    }
  }
</style>
