---
/**
 * Footer - Site footer component
 * HD-2D styled footer for all pages except home
 * Contains copyright, social links, navigation with active states, and CV download
 * 
 * Props:
 * - currentPath: Current page path for active state detection (optional)
 */

import Icon from './Icon.astro';

interface Props {
  currentPath?: string;
}

interface SocialLink {
  name: string;
  url: string;
  icon: string;
}

const { currentPath } = Astro.props;

// Social links - removed Twitter and LinkedIn, added Email
const socialLinks: SocialLink[] = [
  { name: "GitHub", url: "https://github.com/yourusername", icon: "github" },
  { name: "Email", url: "mailto:your.email@example.com", icon: "email" },
];

// Navigation links with bilingual support - updated to match navbar
const navLinks = [
  { label: { id: 'Beranda', en: 'Home' }, href: '/', target: undefined },
  { label: { id: 'Proyek', en: 'Projects' }, href: '/projects', target: '_blank' },
  { label: { id: 'Blog', en: 'Blogs' }, href: '/blogs', target: '_blank' },
  { label: { id: 'Pengalaman', en: 'Experiences' }, href: '/experiences', target: '_blank' },
];

const currentYear = new Date().getFullYear();

// Get current path for active state (fallback to Astro.url.pathname if not provided)
const activePath = currentPath || Astro.url.pathname;
---

<footer class="footer depth-mid" role="contentinfo">
  <div class="footer__container">
    <div class="footer__content">
      <!-- Navigation Links -->
      <nav class="footer__nav" aria-label="Footer navigation">
        <ul class="footer__nav-list">
          {navLinks.map((link) => {
            const isActive = activePath === link.href || 
                            (link.href !== '/' && activePath.startsWith(link.href));
            
            return (
              <li class="footer__nav-item">
                <a 
                  href={link.href} 
                  class:list={['footer__nav-link', { 'footer__nav-link--active': isActive }]}
                  aria-current={isActive ? 'page' : undefined}
                  target={link.target}
                  rel={link.target === '_blank' ? 'noopener noreferrer' : undefined}
                  data-bilingual="footer-nav"
                >
                  <span data-lang="en">{link.label.en}</span>
                  <span data-lang="id">{link.label.id}</span>
                </a>
              </li>
            );
          })}
          <!-- CV Download Button -->
          <li class="footer__nav-item footer__nav-item--cv">
            <a 
              href="/cv.pdf" 
              class="footer__cv-button"
              download
              aria-label="Download CV"
              data-bilingual="cv-button"
            >
              <Icon name="download" class="footer__cv-icon" />
              <span data-lang="en">Download my CV</span>
              <span data-lang="id">Unduh CV saya</span>
            </a>
          </li>
        </ul>
      </nav>

      <!-- Social Links -->
      <div class="footer__social">
        <ul class="footer__social-list">
          {socialLinks.map((link) => (
            <li class="footer__social-item">
              <a 
                href={link.url} 
                class="footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Visit ${link.name} (opens in new tab)`}
              >
                <Icon name={link.icon} class="footer__social-icon" />
                <span class="footer__social-name">{link.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Copyright -->
      <div class="footer__copyright">
        <p class="footer__copyright-text">
          © {currentYear} Gerry Moeis Portfolio.
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface-elevated);
    border-top: var(--panel-border-width) var(--panel-border-style) var(--color-accent-primary);
    box-shadow: 
      var(--panel-shadow-elevated),
      var(--atmospheric-glow);
    position: relative;
    overflow: hidden;
  }

  .footer__container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-8);
    position: relative;
    z-index: 1;
  }

  .footer__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
    text-align: center;
  }

  /* Navigation */
  .footer__nav-list {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer__nav-item {
    margin: 0;
  }
  
  .footer__nav-item--cv {
    /* CV button tidak sejajar dengan text links */
    margin-left: var(--space-4);
  }

  .footer__nav-link {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    position: relative;
    transition: 
      color var(--duration-medium) var(--ease-out),
      background-color var(--duration-medium) var(--ease-out);
  }
  
  /* Hide inactive language */
  .footer__nav-link span[data-lang] {
    display: none;
  }
  
  /* Show active language */
  :global(html[lang="en"]) .footer__nav-link span[data-lang="en"],
  :global(html[lang="id"]) .footer__nav-link span[data-lang="id"] {
    display: inline;
  }

  .footer__nav-link:hover {
    color: var(--color-contrast-high);
    background-color: var(--color-nav-hover-bg);
  }

  .footer__nav-link:focus-visible {
    outline: var(--focus-outline-width) var(--focus-outline-style) var(--focus-outline-color);
    outline-offset: var(--focus-outline-offset);
  }

  .footer__nav-link--active {
    color: var(--color-contrast-high);
    background-color: var(--color-nav-active-bg);
    font-weight: var(--weight-semibold);
    box-shadow: var(--subtle-glow);
  }

  .footer__nav-link--active::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * var(--space-1));
    left: 50%;
    transform: translateX(-50%);
    width: var(--nav-indicator-width);
    height: var(--nav-indicator-height);
    background-color: var(--color-nav-active-indicator);
    border-radius: var(--radius-xs);
    box-shadow: 0 0 var(--space-1) var(--color-nav-active-indicator);
  }
  
  /* CV Download Button */
  .footer__cv-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    border-radius: var(--radius-full);
    border: 2px solid transparent;
    transition: all var(--duration-medium) ease;
    box-shadow: 0 0 20px rgba(246, 224, 94, 0.3);
  }
  
  /* Dark theme CV button */
  :global(html:not([data-theme="light"])) .footer__cv-button {
    background: var(--color-accent-primary);
    color: var(--color-bg-primary);
  }
  
  :global(html:not([data-theme="light"])) .footer__cv-button:hover {
    background: var(--color-bg-dark);
    color: #f6e05e;
    border-color: #f6e05e;
    box-shadow: 
      0 0 40px rgba(246, 224, 94, 0.8),
      0 0 20px rgba(246, 224, 94, 0.6),
      inset 0 0 20px rgba(246, 224, 94, 0.1);
    text-shadow: 0 0 10px rgba(246, 224, 94, 0.8);
    transform: translateY(-2px);
  }
  
  /* Light theme CV button */
  :global([data-theme="light"]) .footer__cv-button {
    background: #ff5500;
    color: #ffffff;
    box-shadow: 0 0 20px rgba(255, 85, 0, 0.3);
  }
  
  :global([data-theme="light"]) .footer__cv-button:hover {
    background: #ffffff;
    color: #ff5500;
    border-color: #ff5500;
    box-shadow: 
      0 0 40px rgba(255, 85, 0, 0.8),
      0 0 20px rgba(255, 85, 0, 0.6),
      inset 0 0 20px rgba(255, 85, 0, 0.1);
    text-shadow: 0 0 10px rgba(255, 85, 0, 0.8);
    transform: translateY(-2px);
  }
  
  .footer__cv-button:focus-visible {
    outline: var(--focus-outline-width) var(--focus-outline-style) var(--focus-outline-color);
    outline-offset: var(--focus-outline-offset);
  }
  
  .footer__cv-button:active {
    transform: translateY(0);
  }
  
  .footer__cv-icon {
    font-size: var(--text-lg);
    line-height: 1;
  }
  
  /* Hide inactive language for CV button */
  .footer__cv-button span[data-lang] {
    display: none;
  }
  
  /* Show active language for CV button */
  :global(html[lang="en"]) .footer__cv-button span[data-lang="en"],
  :global(html[lang="id"]) .footer__cv-button span[data-lang="id"] {
    display: inline;
  }

  /* Social Links - Larger size for better hierarchy */
  .footer__social-list {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__social-item {
    margin: 0;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-lg); /* Larger text size */
    font-weight: var(--weight-medium);
    color: var(--color-text-tertiary);
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    transition: 
      color var(--duration-medium) var(--ease-out),
      background-color var(--duration-medium) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .footer__social-link:hover {
    color: var(--color-contrast-high);
    background-color: var(--color-social-hover-bg);
    transform: var(--transform-hover-lift);
  }

  .footer__social-link:focus-visible {
    outline: var(--focus-outline-width) var(--focus-outline-style) var(--focus-outline-color);
    outline-offset: var(--focus-outline-offset);
  }

  .footer__social-icon {
    font-size: var(--text-2xl); /* Larger icon size */
    line-height: 1;
    flex-shrink: 0;
  }

  /* Copyright */
  .footer__copyright-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0;
  }
  
  /* Light mode copyright - better contrast */
  :global([data-theme="light"]) .footer__copyright-text {
    color: var(--color-text-primary);
    opacity: 0.8;
  }

  /* Responsive adjustments - Mobile First */
  @media (max-width: 768px) {
    .footer__container {
      padding: var(--space-12) var(--space-6) var(--space-10);
    }

    .footer__content {
      gap: var(--space-6); /* Reduced base gap */
    }

    /* Navigation - Force Vertical Layout */
    .footer__nav-list {
      flex-direction: column !important;
      flex-wrap: nowrap !important;
      gap: var(--space-4);
      width: 100%;
      align-items: stretch;
    }
    
    .footer__nav-item {
      width: 100%;
      margin: 0;
    }
    
    .footer__nav-item--cv {
      margin-left: 0 !important;
      margin-top: var(--space-6) !important; /* Symmetric spacing */
      margin-bottom: var(--space-6) !important; /* Symmetric spacing */
      padding-top: 0;
      border-top: none;
    }
    
    .footer__nav-link {
      width: 100%;
      text-align: center;
      display: block;
      padding: var(--space-3) var(--space-5);
      font-size: var(--text-base);
    }
    
    .footer__cv-button {
      width: 100%;
      padding: var(--space-3) var(--space-5);
      font-size: var(--text-base);
    }

    /* Social Links - Vertical Stack */
    .footer__social-list {
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: var(--space-5);
      width: 100%;
    }

    .footer__social-link {
      flex-direction: row;
      justify-content: center;
      text-align: center;
      padding: var(--space-3) var(--space-5);
      gap: var(--space-3);
      width: 100%;
      max-width: 300px;
    }

    .footer__social-name {
      font-size: var(--text-lg);
    }
    
    .footer__social-icon {
      font-size: var(--text-2xl);
    }
    
    .footer__copyright-text {
      font-size: var(--text-base);
      padding: 0 var(--space-4);
    }
  }

  @media (max-width: 480px) {
    .footer__container {
      padding: var(--space-10) var(--space-4) var(--space-8);
    }
    
    .footer__content {
      gap: var(--space-5); /* Reduced base gap */
    }
    
    .footer__nav-list {
      gap: var(--space-3);
    }

    .footer__nav-link {
      font-size: var(--text-sm);
      padding: var(--space-2) var(--space-4);
    }
    
    .footer__nav-item--cv {
      margin-top: var(--space-5) !important; /* Symmetric spacing */
      margin-bottom: var(--space-5) !important; /* Symmetric spacing */
      padding-top: 0;
    }
    
    .footer__cv-button {
      padding: var(--space-3) var(--space-4);
      font-size: var(--text-sm);
    }
    
    .footer__social-list {
      gap: var(--space-4);
    }
    
    .footer__social-link {
      font-size: var(--text-base);
      padding: var(--space-2) var(--space-4);
      gap: var(--space-3);
    }
    
    .footer__social-icon {
      font-size: var(--text-xl);
    }
    
    .footer__social-name {
      font-size: var(--text-base);
    }
    
    .footer__copyright-text {
      font-size: var(--text-sm);
    }
  }
</style>