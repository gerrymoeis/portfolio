---
/**
 * Navigation - Site navigation component with mobile hamburger menu
 * Provides accessible navigation with keyboard support
 * Mobile: Hamburger menu (<768px)
 * Desktop: Horizontal navigation (>=768px)
 * 
 * Props:
 * - class: Additional CSS classes (optional)
 */

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Navigation links - Consistent order: Home, Projects, Blogs
const navLinks = [
  { label: 'Home', href: '/', target: undefined },
  { label: 'Projects', href: '/projects', target: '_blank' },
  { label: 'Blogs', href: '/blogs', target: '_blank' },
];

// Get current path for active state
const currentPath = Astro.url.pathname;
---

<nav class={`navigation ${className}`} aria-label="Main navigation">
  <!-- Mobile hamburger button (visible < 768px) -->
  <button 
    class="navigation__hamburger" 
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    data-nav-toggle
  >
    <span class="navigation__hamburger-line"></span>
    <span class="navigation__hamburger-line"></span>
    <span class="navigation__hamburger-line"></span>
  </button>

  <!-- Navigation menu -->
  <ul class="navigation__list" data-nav-menu>
    {navLinks.map((link) => {
      const isActive = currentPath === link.href || 
                      (link.href !== '/' && currentPath.startsWith(link.href));
      
      return (
        <li class="navigation__item">
          <a 
            href={link.href} 
            class:list={['navigation__link', { 'navigation__link--active': isActive }]}
            aria-current={isActive ? 'page' : undefined}
            target={link.target}
            rel={link.target === '_blank' ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>

  <!-- Mobile overlay (visible when menu is open) -->
  <div class="navigation__overlay" data-nav-overlay></div>
</nav>

<script>
  // Mobile navigation toggle
  const navToggle = document.querySelector('[data-nav-toggle]');
  const navMenu = document.querySelector('[data-nav-menu]');
  const navOverlay = document.querySelector('[data-nav-overlay]');
  const navLinks = document.querySelectorAll('.navigation__link');

  function openMenu() {
    navMenu?.classList.add('is-open');
    navOverlay?.classList.add('is-visible');
    navToggle?.classList.add('is-active');
    navToggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden'; // Prevent background scroll
  }

  function closeMenu() {
    navMenu?.classList.remove('is-open');
    navOverlay?.classList.remove('is-visible');
    navToggle?.classList.remove('is-active');
    navToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = ''; // Restore scroll
  }

  function toggleMenu() {
    const isOpen = navMenu?.classList.contains('is-open');
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  // Toggle menu on button click
  navToggle?.addEventListener('click', toggleMenu);

  // Close menu on overlay click
  navOverlay?.addEventListener('click', closeMenu);

  // Close menu on link click (mobile)
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 768) {
        closeMenu();
      }
    });
  });

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && navMenu?.classList.contains('is-open')) {
      closeMenu();
    }
  });

  // Close menu on window resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && navMenu?.classList.contains('is-open')) {
      closeMenu();
    }
  });
</script>

<style>
  .navigation {
    width: 100%;
  }

  /* ============================================
     MOBILE HAMBURGER BUTTON
     ============================================ */
  
  .navigation__hamburger {
    display: none; /* Hidden on desktop */
    position: fixed;
    top: var(--space-4);
    right: var(--space-4);
    z-index: var(--layer-navigation);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 48px;
    height: 48px;
    background: var(--color-surface-elevated);
    border: var(--panel-border-width) var(--panel-border-style) var(--color-accent-primary);
    border-radius: var(--radius-md);
    box-shadow: var(--panel-shadow-elevated);
    backdrop-filter: blur(var(--blur-backdrop-light));
    cursor: pointer;
    transition: all var(--duration-medium) var(--ease-out);
  }

  .navigation__hamburger:hover {
    background: var(--color-nav-hover-bg);
    transform: var(--transform-hover-lift);
  }

  .navigation__hamburger:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  .navigation__hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: all var(--duration-medium) var(--ease-out);
  }

  /* Hamburger animation when open */
  .navigation__hamburger.is-active .navigation__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .navigation__hamburger.is-active .navigation__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .navigation__hamburger.is-active .navigation__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ============================================
     MOBILE OVERLAY
     ============================================ */
  
  .navigation__overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: calc(var(--layer-navigation) - 1);
    opacity: 0;
    transition: opacity var(--duration-medium) var(--ease-out);
  }

  .navigation__overlay.is-visible {
    display: block;
    opacity: 1;
  }

  /* ============================================
     NAVIGATION LIST (DESKTOP & MOBILE)
     ============================================ */

  .navigation__list {
    display: flex;
    gap: var(--space-8);
    align-items: center;
    justify-content: center;
    list-style: none;
    background: var(--color-surface-elevated);
    border: var(--panel-border-width) var(--panel-border-style) var(--color-accent-primary);
    border-radius: var(--radius-pill);
    box-shadow: 
      var(--panel-shadow-elevated),
      var(--atmospheric-glow);
    backdrop-filter: blur(var(--blur-backdrop-light));
    padding: var(--space-3) var(--space-6);
    position: relative;
    overflow: hidden;
    max-width: var(--nav-max-width);
    margin: 0 auto;
  }

  /* HD-2D atmospheric overlay */
  .navigation__list::before {
    content: '';
    position: absolute;
    inset: var(--space-1);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-nav-pill);
    pointer-events: none;
  }

  .navigation__list::after {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 30% 30%, var(--color-particle-warm) 0%, transparent 60%),
      radial-gradient(circle at 70% 70%, var(--color-particle-cool) 0%, transparent 60%);
    pointer-events: none;
    border-radius: var(--radius-pill);
  }

  .navigation__item {
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .navigation__link {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-nav-link);
    transition: 
      color var(--duration-medium) var(--ease-out),
      background-color var(--duration-medium) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-medium) var(--ease-out);
    position: relative;
    white-space: nowrap;
  }

  .navigation__link:hover {
    color: var(--color-contrast-high);
    background-color: var(--color-nav-hover-bg);
    transform: var(--transform-hover-lift);
    box-shadow: var(--subtle-glow);
  }

  .navigation__link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  .navigation__link--active {
    color: var(--color-contrast-high);
    background-color: var(--color-nav-active-bg);
    font-weight: var(--weight-semibold);
    box-shadow: var(--subtle-glow);
  }

  .navigation__link--active::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * var(--space-1));
    left: 50%;
    transform: translateX(-50%);
    width: var(--nav-indicator-width);
    height: var(--nav-indicator-height);
    background-color: var(--color-nav-active-indicator);
    border-radius: var(--radius-xs);
    box-shadow: 0 0 var(--space-1) var(--color-nav-active-indicator);
  }

  /* ============================================
     MOBILE NAVIGATION (<768px)
     ============================================ */

  @media (max-width: 767px) {
    /* Show hamburger button */
    .navigation__hamburger {
      display: flex;
    }

    /* Transform navigation list to mobile menu */
    .navigation__list {
      position: fixed;
      top: 0;
      right: -100%;
      width: 280px;
      max-width: 85vw;
      height: 100vh;
      flex-direction: column;
      justify-content: flex-start;
      align-items: stretch;
      gap: 0;
      padding: var(--space-20) var(--space-6) var(--space-6);
      border-radius: 0;
      border-right: none;
      border-top: none;
      border-bottom: none;
      z-index: var(--layer-navigation);
      transition: right var(--duration-medium) var(--ease-out);
      overflow-y: auto;
    }

    .navigation__list.is-open {
      right: 0;
    }

    /* Remove atmospheric overlays on mobile */
    .navigation__list::before,
    .navigation__list::after {
      display: none;
    }

    .navigation__item {
      width: 100%;
    }

    .navigation__link {
      width: 100%;
      padding: var(--space-4);
      font-size: var(--text-lg);
      text-align: left;
      border-radius: var(--radius-md);
    }

    .navigation__link--active::after {
      display: none; /* Remove indicator on mobile */
    }
  }

  /* ============================================
     RESPONSIVE ADJUSTMENTS - DESKTOP
     ============================================ */

  /* Extra small devices - compact navigation */
  @media (min-width: 768px) and (max-width: var(--breakpoint-xs)) {
    .navigation__list {
      gap: var(--space-1);
      padding: var(--space-2) var(--space-3);
      max-width: 90vw;
    }

    .navigation__link {
      font-size: var(--text-xs);
      padding: var(--space-1) var(--space-2);
      border-radius: var(--radius-sm);
    }
  }

  /* Small devices - slightly larger but still compact */
  @media (min-width: var(--breakpoint-xs)) and (max-width: var(--breakpoint-sm)) {
    .navigation__list {
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      max-width: 85vw;
    }

    .navigation__link {
      font-size: var(--text-sm);
      padding: var(--space-1) var(--space-3);
    }
  }

  /* Medium devices - balanced sizing */
  @media (min-width: var(--breakpoint-sm)) and (max-width: var(--breakpoint-lg)) {
    .navigation__list {
      gap: var(--space-4);
      padding: var(--space-2) var(--space-4);
      max-width: 80vw;
    }

    .navigation__link {
      font-size: var(--text-sm);
      padding: var(--space-1) var(--space-3);
    }
  }

  /* Large devices - full sizing */
  @media (min-width: var(--breakpoint-lg)) {
    .navigation__list {
      gap: var(--space-8);
      padding: var(--space-3) var(--space-6);
      max-width: var(--nav-max-width);
    }

    .navigation__link {
      font-size: var(--text-base);
      padding: var(--space-2) var(--space-4);
    }
  }

  /* Ultra-wide screens - prevent over-expansion */
  @media (min-width: var(--breakpoint-2xl)) {
    .navigation__list {
      max-width: 500px;
    }
  }

  /* Landscape orientation on mobile - adjust for limited height */
  @media (max-height: 600px) and (orientation: landscape) and (max-width: var(--breakpoint-lg)) {
    .navigation__list {
      padding: var(--space-1) var(--space-3);
      gap: var(--space-2);
    }

    .navigation__link {
      padding: var(--space-1) var(--space-2);
      font-size: var(--text-xs);
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .navigation__list {
      border-width: 2px;
      border-color: var(--color-accent-primary);
    }

    .navigation__link {
      border: 1px solid transparent;
    }

    .navigation__link:hover,
    .navigation__link--active {
      border-color: var(--color-accent-primary);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .navigation__link,
    .navigation__hamburger,
    .navigation__hamburger-line,
    .navigation__list,
    .navigation__overlay {
      transition: none;
    }

    .navigation__link:hover {
      transform: none;
    }
  }

  /* Touch device optimizations */
  @media (hover: none) and (pointer: coarse) {
    .navigation__link {
      padding: var(--space-3) var(--space-4);
      min-height: 44px; /* Minimum touch target size */
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .navigation__list {
      gap: var(--space-2);
    }
  }

  /* Container queries for adaptive behavior */
  @container (max-width: 400px) {
    .navigation__list {
      gap: var(--space-1);
      padding: var(--space-2) var(--space-3);
    }

    .navigation__link {
      font-size: var(--text-xs);
      padding: var(--space-1) var(--space-2);
    }
  }

  @container (min-width: 400px) and (max-width: 600px) {
    .navigation__list {
      gap: var(--space-4);
      padding: var(--space-2) var(--space-4);
    }

    .navigation__link {
      font-size: var(--text-sm);
      padding: var(--space-2) var(--space-3);
    }
  }
</style>
