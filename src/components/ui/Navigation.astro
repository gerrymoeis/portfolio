---
/**
 * Navigation - Site navigation component (DESKTOP ONLY)
 * Mobile navigation is handled separately in PageContainer
 * 
 * Props:
 * - class: Additional CSS classes (optional)
 */

import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Navigation links with bilingual support - Consistent order: Home, Projects, Blogs, Experiences, CV
const navLinks = [
  { label: { id: 'Beranda', en: 'Home' }, href: '/', target: undefined },
  { label: { id: 'Proyek', en: 'Projects' }, href: '/projects', target: '_blank' },
  { label: { id: 'Blog', en: 'Blogs' }, href: '/blogs', target: '_blank' },
  { label: { id: 'Pengalaman', en: 'Experiences' }, href: '/experiences', target: '_blank' },
  { label: { id: 'CV', en: 'CV' }, href: '/cv', target: '_blank' },
];

// Get current path for active state
const currentPath = Astro.url.pathname;
---

<!-- Desktop navigation wrapper -->
<nav class={`navigation ${className}`} aria-label="Main navigation">
  <!-- Navigation menu -->
  <ul class="navigation__list">
    {navLinks.map((link) => {
      const isActive = currentPath === link.href || 
                      (link.href !== '/' && currentPath.startsWith(link.href));
      
      return (
        <li class="navigation__item">
          <a 
            href={link.href} 
            class:list={['navigation__link', { 'navigation__link--active': isActive }]}
            aria-label={`Navigate to ${link.label.en}`}
            aria-current={isActive ? 'page' : undefined}
            target={link.target}
            rel={link.target === '_blank' ? 'noopener noreferrer' : undefined}
            data-bilingual="nav"
          >
            <span data-lang="en">{link.label.en}</span>
            <span data-lang="id">{link.label.id}</span>
          </a>
        </li>
      );
    })}
    <li class="navigation__item navigation__item--controls">
      <div class="navigation__controls">
        <LanguageToggle />
        <ThemeToggle />
      </div>
    </li>
  </ul>
</nav>

<style>
  .navigation {
    width: 100%;
  }

  /* ============================================
     NAVIGATION LIST (DESKTOP ONLY)
     ============================================ */

  .navigation__list {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    justify-content: center;
    list-style: none;
    background: var(--color-surface-elevated);
    border: var(--panel-border-width) var(--panel-border-style) var(--color-accent-primary);
    border-radius: var(--radius-pill);
    box-shadow: 
      var(--panel-shadow-elevated),
      var(--atmospheric-glow);
    backdrop-filter: blur(var(--blur-backdrop-light));
    padding: var(--space-3) var(--space-6);
    position: relative;
    overflow: hidden;
    max-width: fit-content;
    margin: 0 auto;
  }

  /* HD-2D atmospheric overlay */
  .navigation__list::before {
    content: '';
    position: absolute;
    inset: var(--space-1);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-nav-pill);
    pointer-events: none;
  }

  .navigation__list::after {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 40% 30% at 50% 0%, var(--color-particle-warm) 0%, transparent 50%);
    pointer-events: none;
    border-radius: var(--radius-pill);
  }

  .navigation__item {
    margin: 0;
    position: relative;
    z-index: 1;
  }
  
  .navigation__item--controls {
    margin-left: var(--space-2);
    padding-left: var(--space-4);
    border-left: 1px solid var(--color-border-medium);
  }
  
  .navigation__controls {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }

  .navigation__link {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-nav-link);
    transition: 
      color var(--duration-medium) var(--ease-out),
      background-color var(--duration-medium) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-medium) var(--ease-out);
    position: relative;
    white-space: nowrap;
  }
  
  /* Hide inactive language */
  .navigation__link span[data-lang] {
    display: none;
  }
  
  /* Show active language */
  :global(html[lang="en"]) .navigation__link span[data-lang="en"],
  :global(html[lang="id"]) .navigation__link span[data-lang="id"] {
    display: inline;
  }

  .navigation__link:hover {
    color: var(--color-text-primary);
    background-color: var(--color-nav-hover-bg);
    transform: translateY(-1px);
    box-shadow: var(--subtle-glow);
  }
  
  /* Dark theme hover - golden yellow */
  :global(html:not([data-theme="light"])) .navigation__link:hover {
    background-color: rgba(246, 224, 94, 0.25);
  }
  
  /* Light theme hover - red-orange */
  :global([data-theme="light"]) .navigation__link:hover {
    background-color: rgba(255, 85, 0, 0.25);
  }

  .navigation__link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  .navigation__link--active {
    color: var(--color-text-primary);
    background-color: var(--color-nav-active-bg);
    font-weight: var(--weight-semibold);
    box-shadow: var(--subtle-glow);
  }
  
  /* Dark theme active - golden yellow */
  :global(html:not([data-theme="light"])) .navigation__link--active {
    background-color: rgba(246, 224, 94, 0.35);
  }
  
  /* Light theme active - red-orange */
  :global([data-theme="light"]) .navigation__link--active {
    background-color: rgba(255, 85, 0, 0.35);
  }

  .navigation__link--active::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * var(--space-1));
    left: 50%;
    transform: translateX(-50%);
    width: var(--nav-indicator-width);
    height: var(--nav-indicator-height);
    background-color: var(--color-accent-primary);
    border-radius: var(--radius-xs);
    box-shadow: 0 0 var(--space-1) var(--color-accent-primary);
  }
</style>