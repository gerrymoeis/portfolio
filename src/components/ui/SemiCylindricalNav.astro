---
/**
 * SemiCylindricalNav - Semi-cylindrical/half-arc navigation bar with mobile hamburger menu
 * Centered horizontally at the top of the home page
 * Contains Home, Projects, Blogs links with bilingual support
 * Mobile: Hamburger menu (<768px)
 * Desktop: Horizontal navigation (>=768px)
 */

import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';
import type { BilingualText } from '../../config/home';

interface NavigationLink {
  label: BilingualText;
  href: string;
  target?: string;
}

interface Props {
  links: NavigationLink[];
  currentPath?: string;
}

const { links, currentPath = '/' } = Astro.props;
---

<nav class="semi-cylindrical-nav" aria-label="Main navigation">
  <!-- Mobile hamburger button (visible < 768px) -->
  <button 
    class="semi-cylindrical-nav__hamburger" 
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    data-nav-toggle
  >
    <span class="semi-cylindrical-nav__hamburger-line"></span>
    <span class="semi-cylindrical-nav__hamburger-line"></span>
    <span class="semi-cylindrical-nav__hamburger-line"></span>
  </button>

  <div class="semi-cylindrical-nav__container" data-nav-menu>
    <ul class="semi-cylindrical-nav__list">
      {links.map((link) => (
        <li class="semi-cylindrical-nav__item">
          <a 
            href={link.href} 
            class={`semi-cylindrical-nav__link ${currentPath === link.href ? 'semi-cylindrical-nav__link--active' : ''}`}
            aria-label={`Navigate to ${link.label.en}`}
            aria-current={currentPath === link.href ? 'page' : undefined}
            target={link.target}
            rel={link.target === '_blank' ? 'noopener noreferrer' : undefined}
            data-bilingual="nav"
          >
            <span data-lang="en">{link.label.en}</span>
            <span data-lang="id">{link.label.id}</span>
          </a>
        </li>
      ))}
      <li class="semi-cylindrical-nav__item semi-cylindrical-nav__item--controls">
        <div class="semi-cylindrical-nav__controls">
          <LanguageToggle />
          <ThemeToggle />
        </div>
      </li>
    </ul>
  </div>

  <!-- Mobile overlay (visible when menu is open) -->
  <div class="semi-cylindrical-nav__overlay" data-nav-overlay></div>
</nav>

<script>
  // Mobile navigation toggle
  const navToggle = document.querySelector('[data-nav-toggle]');
  const navMenu = document.querySelector('[data-nav-menu]');
  const navOverlay = document.querySelector('[data-nav-overlay]');
  const navLinks = document.querySelectorAll('.semi-cylindrical-nav__link');

  function openMenu() {
    navMenu?.classList.add('is-open');
    navOverlay?.classList.add('is-visible');
    navToggle?.classList.add('is-active');
    navToggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden'; // Prevent background scroll
  }

  function closeMenu() {
    navMenu?.classList.remove('is-open');
    navOverlay?.classList.remove('is-visible');
    navToggle?.classList.remove('is-active');
    navToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = ''; // Restore scroll
  }

  function toggleMenu() {
    const isOpen = navMenu?.classList.contains('is-open');
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  // Toggle menu on button click
  navToggle?.addEventListener('click', toggleMenu);

  // Close menu on overlay click
  navOverlay?.addEventListener('click', closeMenu);

  // Close menu on link click (mobile)
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 768) {
        closeMenu();
      }
    });
  });

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && navMenu?.classList.contains('is-open')) {
      closeMenu();
    }
  });

  // Close menu on window resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && navMenu?.classList.contains('is-open')) {
      closeMenu();
    }
  });
</script>

<style>
  /* ============================================
     MOBILE HAMBURGER BUTTON
     ============================================ */
  
  .semi-cylindrical-nav__hamburger {
    display: none; /* Hidden on desktop */
    position: fixed;
    top: var(--space-4);
    right: var(--space-4);
    z-index: calc(var(--layer-navigation) + 1);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 48px;
    height: 48px;
    background: var(--color-surface-elevated);
    border: var(--panel-border-width) var(--panel-border-style) var(--color-accent-primary);
    border-radius: var(--radius-md);
    box-shadow: var(--panel-shadow-elevated);
    backdrop-filter: blur(var(--blur-backdrop-light));
    cursor: pointer;
    transition: all var(--duration-medium) var(--ease-out);
  }

  .semi-cylindrical-nav__hamburger:hover {
    background: var(--color-nav-hover-bg);
    transform: var(--transform-hover-lift);
  }

  .semi-cylindrical-nav__hamburger:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  .semi-cylindrical-nav__hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: all var(--duration-medium) var(--ease-out);
  }

  /* Hamburger animation when open */
  .semi-cylindrical-nav__hamburger.is-active .semi-cylindrical-nav__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .semi-cylindrical-nav__hamburger.is-active .semi-cylindrical-nav__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .semi-cylindrical-nav__hamburger.is-active .semi-cylindrical-nav__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ============================================
     MOBILE OVERLAY
     ============================================ */
  
  .semi-cylindrical-nav__overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7); /* Darker overlay without blur */
    z-index: calc(var(--layer-navigation) - 1); /* Below menu */
    opacity: 0;
    transition: opacity var(--duration-medium) var(--ease-out);
  }

  .semi-cylindrical-nav__overlay.is-visible {
    display: block;
    opacity: 1;
  }

  /* ============================================
     NAVIGATION CONTAINER & LIST
     ============================================ */

  .semi-cylindrical-nav {
    position: fixed;
    top: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--layer-navigation);
    width: 100%;
    max-width: calc(100vw - var(--space-4));
    display: flex;
    justify-content: center;
  }

  .semi-cylindrical-nav__container {
    background: var(--color-surface-elevated);
    border: var(--panel-border-width) var(--panel-border-style) var(--color-accent-primary);
    border-radius: 50px; /* Semi-cylindrical shape */
    box-shadow: 
      var(--panel-shadow-elevated),
      var(--atmospheric-glow);
    backdrop-filter: blur(10px);
    padding: var(--space-3) var(--space-6);
    position: relative;
    overflow: hidden;
    max-width: 100%;
  }

  /* HD-2D atmospheric overlay */
  .semi-cylindrical-nav__container::before {
    content: '';
    position: absolute;
    inset: 2px;
    border: 1px solid rgba(246, 224, 94, 0.3);
    border-radius: 48px;
    pointer-events: none;
  }

  .semi-cylindrical-nav__container::after {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 30% 30%, rgba(246, 224, 94, 0.08) 0%, transparent 60%),
      radial-gradient(circle at 70% 70%, rgba(237, 137, 54, 0.05) 0%, transparent 60%);
    pointer-events: none;
    border-radius: 50px;
  }

  .semi-cylindrical-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 1;
  }

  .semi-cylindrical-nav__item {
    margin: 0;
  }
  
  .semi-cylindrical-nav__item--controls {
    margin-left: var(--space-2);
  }
  
  .semi-cylindrical-nav__controls {
    display: flex;
    gap: var(--space-2);
    align-items: center;
  }

  .semi-cylindrical-nav__link {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: 20px;
    transition: 
      color var(--duration-medium) var(--ease-out),
      background-color var(--duration-medium) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-medium) var(--ease-out);
    position: relative;
    white-space: nowrap;
  }
  
  /* Hide inactive language */
  .semi-cylindrical-nav__link span[data-lang] {
    display: none;
  }
  
  /* Show active language */
  :global(html[lang="en"]) .semi-cylindrical-nav__link span[data-lang="en"],
  :global(html[lang="id"]) .semi-cylindrical-nav__link span[data-lang="id"] {
    display: inline;
  }

  .semi-cylindrical-nav__link:hover {
    color: var(--color-text-primary);
    background-color: rgba(246, 224, 94, 0.1);
    transform: translateY(-1px);
    box-shadow: var(--subtle-glow);
  }

  .semi-cylindrical-nav__link:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  .semi-cylindrical-nav__link--active {
    color: var(--color-text-primary);
    background-color: rgba(246, 224, 94, 0.15);
    font-weight: var(--weight-semibold);
    box-shadow: var(--subtle-glow);
  }

  .semi-cylindrical-nav__link--active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 2px;
    background-color: var(--color-accent-primary);
    border-radius: 1px;
    box-shadow: 0 0 4px var(--color-accent-primary);
  }

  /* ============================================
     MOBILE NAVIGATION (<768px)
     ============================================ */

  @media (max-width: 767px) {
    /* Show hamburger button */
    .semi-cylindrical-nav__hamburger {
      display: flex;
    }

    /* Hide desktop nav positioning */
    .semi-cylindrical-nav {
      position: static;
      transform: none;
      left: auto;
      top: auto;
    }

    /* Transform navigation container to mobile menu */
    .semi-cylindrical-nav__container {
      position: fixed;
      top: 0;
      right: -100%;
      width: 280px;
      max-width: 85vw;
      height: 100vh;
      border-radius: 0;
      border-right: none;
      border-top: none;
      border-bottom: none;
      z-index: var(--layer-navigation); /* Above overlay */
      transition: right var(--duration-medium) var(--ease-out);
      overflow-y: auto;
      padding: var(--space-20) var(--space-6) var(--space-6);
    }

    .semi-cylindrical-nav__container.is-open {
      right: 0;
    }

    /* Remove atmospheric overlays on mobile */
    .semi-cylindrical-nav__container::before,
    .semi-cylindrical-nav__container::after {
      display: none;
    }

    .semi-cylindrical-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .semi-cylindrical-nav__item {
      width: 100%;
    }

    .semi-cylindrical-nav__item--controls {
      margin-left: 0;
      margin-top: var(--space-4);
      padding-top: var(--space-4);
      border-top: 1px solid var(--color-border-medium);
    }

    .semi-cylindrical-nav__controls {
      justify-content: center;
      gap: var(--space-4);
    }

    .semi-cylindrical-nav__link {
      width: 100%;
      padding: var(--space-4);
      font-size: var(--text-lg);
      text-align: left;
      border-radius: var(--radius-md);
    }

    .semi-cylindrical-nav__link--active::after {
      display: none; /* Remove indicator on mobile */
    }
  }

  /* ============================================
     RESPONSIVE ADJUSTMENTS - DESKTOP
     ============================================ */

  /* Extra small devices - very compact navigation */
  @media (min-width: 768px) and (max-width: var(--breakpoint-xs)) {
    .semi-cylindrical-nav {
      top: var(--space-2);
      max-width: calc(100vw - var(--space-2));
    }

    .semi-cylindrical-nav__container {
      padding: var(--space-1) var(--space-3);
    }

    .semi-cylindrical-nav__list {
      gap: var(--space-1);
    }

    .semi-cylindrical-nav__link {
      font-size: var(--text-xs);
      padding: var(--space-1) var(--space-2);
      border-radius: 12px;
    }
  }

  /* Small devices - compact but readable */
  @media (min-width: var(--breakpoint-xs)) and (max-width: var(--breakpoint-sm)) {
    .semi-cylindrical-nav {
      top: var(--space-3);
      max-width: calc(100vw - var(--space-3));
    }

    .semi-cylindrical-nav__container {
      padding: var(--space-2) var(--space-4);
    }

    .semi-cylindrical-nav__list {
      gap: var(--space-2);
    }

    .semi-cylindrical-nav__link {
      font-size: var(--text-sm);
      padding: var(--space-1) var(--space-3);
      border-radius: 16px;
    }
  }

  /* Medium devices - balanced sizing */
  @media (min-width: var(--breakpoint-sm)) and (max-width: var(--breakpoint-lg)) {
    .semi-cylindrical-nav {
      top: var(--space-4);
      max-width: calc(100vw - var(--space-4));
    }

    .semi-cylindrical-nav__container {
      padding: var(--space-2) var(--space-4);
    }

    .semi-cylindrical-nav__list {
      gap: var(--space-4);
    }

    .semi-cylindrical-nav__link {
      font-size: var(--text-sm);
      padding: var(--space-1) var(--space-3);
    }
  }

  /* Large devices - full sizing */
  @media (min-width: var(--breakpoint-lg)) {
    .semi-cylindrical-nav {
      top: var(--space-6);
      max-width: calc(100vw - var(--space-6));
    }

    .semi-cylindrical-nav__container {
      padding: var(--space-3) var(--space-6);
    }

    .semi-cylindrical-nav__list {
      gap: var(--space-8);
    }

    .semi-cylindrical-nav__link {
      font-size: var(--text-base);
      padding: var(--space-2) var(--space-4);
    }
  }

  /* Ultra-wide screens - prevent over-expansion */
  @media (min-width: var(--breakpoint-2xl)) {
    .semi-cylindrical-nav__container {
      max-width: 500px;
    }
  }

  /* Landscape orientation on mobile - adjust for limited height */
  @media (max-height: 600px) and (orientation: landscape) and (max-width: var(--breakpoint-lg)) {
    .semi-cylindrical-nav {
      top: var(--space-2);
    }

    .semi-cylindrical-nav__container {
      padding: var(--space-1) var(--space-3);
    }

    .semi-cylindrical-nav__list {
      gap: var(--space-2);
    }

    .semi-cylindrical-nav__link {
      padding: var(--space-1) var(--space-2);
      font-size: var(--text-xs);
    }
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .semi-cylindrical-nav__container {
      border-width: 2px;
      border-color: var(--color-accent-primary);
    }

    .semi-cylindrical-nav__link {
      border: 1px solid transparent;
    }

    .semi-cylindrical-nav__link:hover,
    .semi-cylindrical-nav__link--active {
      border-color: var(--color-accent-primary);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .semi-cylindrical-nav__link,
    .semi-cylindrical-nav__hamburger,
    .semi-cylindrical-nav__hamburger-line,
    .semi-cylindrical-nav__container,
    .semi-cylindrical-nav__overlay {
      transition: none;
    }

    .semi-cylindrical-nav__link:hover {
      transform: none;
    }
  }

  /* Touch device optimizations */
  @media (hover: none) and (pointer: coarse) {
    .semi-cylindrical-nav__link {
      padding: var(--space-3) var(--space-4);
      min-height: 44px; /* Minimum touch target size */
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .semi-cylindrical-nav__list {
      gap: var(--space-2);
    }
  }

  /* Safe area adjustments for devices with notches */
  @supports (padding: max(0px)) {
    .semi-cylindrical-nav {
      padding-left: max(var(--space-2), env(safe-area-inset-left));
      padding-right: max(var(--space-2), env(safe-area-inset-right));
      padding-top: max(var(--space-2), env(safe-area-inset-top));
    }
  }
</style>